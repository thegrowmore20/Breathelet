        { "value": "normal", "label": "t:sections.rich-text.settings.content_width.options__1.label" },
        { "value": "large", "label": "t:sections.rich-text.settings.content_width.options__2.label" },
        { "value": "extra-large", "label": "t:sections.rich-text.settings.content_width.options__3.label" },
        { "value": "full-width", "label": "t:sections.rich-text.settings.content_width.options__4.label" }
      ],
      "default": "large"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#c9a96e"
    },
    {
      "type": "header",
      "content": "t:sections.all.headers.heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.all.subheading.label",
      "default": "Why Join"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured-collection.settings.heading.label",
