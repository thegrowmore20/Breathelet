    }
  ],
  "presets": [
    {
      "name": "Affiliate · Why join",
      "category": "Affiliate",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Monthly Commissions", "text": "<p>Earn commission for every valid sale you generate through your affiliate link or discount code.</p>" } },
        { "type": "benefit", "settings": { "title": "No Minimum Payout", "text": "<p>No waiting around for a payout threshold. Once you earn it, you can get paid monthly.</p>" } },
        { "type": "benefit", "settings": { "title": "Easy To Promote", "text": "<p>Share a product built around mindfulness, stress relief, better breathing, and screen-free calm.</p>" } },
        { "type": "benefit", "settings": { "title": "Auto-Tracked Sales", "text": "<p>Your referrals are tracked automatically through your link or code, because manual tracking is where joy goes to die.</p>" } },
        { "type": "benefit", "settings": { "title": "Marketing Support", "text": "<p>Get access to product messaging and promotional support to help you share Breathelet with confidence.</p>" } },
        { "type": "benefit", "settings": { "title": "Real Product Appeal", "text": "<p>Promote a wearable mindfulness product that looks premium, feels intentional, and fits modern wellness routines.</p>" } }
      ]
    }
  ]
}
{% endschema %}
