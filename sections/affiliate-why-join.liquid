{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
    --awj-accent: {{ section.settings.accent_color }};
    --awj-accent-rgb: {{ section.settings.accent_color.red }} {{ section.settings.accent_color.green }} {{ section.settings.accent_color.blue }};
  }
</style>

{% liquid
  assign section_classes = ' awj-section '

  if section.settings.remove_horizontal_space
    assign section_classes = section_classes | append: ' !px-0 '
  endif

  if section.settings.remove_vertical_space
    assign section_classes = section_classes | append: ' !py-0 '
  endif
%}

<section {% render 'section-attrs', class: section_classes %}>
  <div class="section-body max-w-[--content-width] mx-auto">

    {% render 'section-header' %}

    {% if section.blocks.size > 0 %}
      <div class="awj-grid" data-animation-auto-order>
        {% for block in section.blocks %}
          <article
            class="awj-card relative overflow-hidden"
            data-animation="block"
            data-animation-group="{{ section.id }}-cards"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.icon_image != blank %}
              {% assign icon_sizes = block.settings.icon_width | append: 'px' %}
              <div class="awj-card__icon" style="width: {{ block.settings.icon_width }}px;">
                {{
                  block.settings.icon_image
                  | image_url: width: 240
                  | image_tag:
                    widths: '60, 120, 180, 240',
                    sizes: icon_sizes,
                    alt: block.settings.icon_image.alt,
                    loading: 'lazy'
                }}
              </div>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="awj-card__title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="awj-card__desc">{{ block.settings.text }}</div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* Vertical/horizontal spacing comes from the theme .section class. */
  .awj-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    text-align: left;
  }

  .awj-card {
    padding: 32px 28px;
    border-radius: 16px;
    background: rgb(var(--color-foreground) / 0.07);
    border: 1px solid rgb(var(--color-foreground) / 0.12);
    transition: 0.25s ease;
  }

  .awj-card:hover {
    background: rgb(var(--awj-accent-rgb) / 0.04);
    border-color: rgb(var(--awj-accent-rgb) / 0.3);
  }

  .awj-card__icon {
    margin-bottom: 16px;
    max-width: 100%;
  }

  .awj-card__icon img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .awj-card__title {
    margin-bottom: 10px;
    font-size: var(--size-text-base);
    font-weight: 600;
    color: rgb(var(--color-foreground));
  }

  .awj-card__desc {
    font-size: var(--size-text-sm);
    line-height: 1.7;
    color: rgb(var(--color-foreground) / 0.65);
  }

  @media (max-width: 900px) {
    .awj-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .awj-grid { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Affiliate · Why join",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.all.full_width.label",
      "default": true
