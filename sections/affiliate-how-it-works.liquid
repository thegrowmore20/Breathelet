{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
  }
</style>

{% liquid
  assign section_classes = ' awh-section '

  if section.settings.remove_horizontal_space
    assign section_classes = section_classes | append: ' !px-0 '
  endif

  if section.settings.remove_vertical_space
    assign section_classes = section_classes | append: ' !py-0 '
  endif

  assign step_tag = section.settings.card_heading_html_tag | default: 'h3'
%}

<section id="affiliate-how-it-works" {% render 'section-attrs', class: section_classes %}>
  <div class="section-body max-w-[--content-width] mx-auto">

    {% render 'section-header', button: false %}

    <div class="awh-steps relative" data-animation-auto-order>
      {% for i in (1..4) %}
        {% liquid
          assign title_key = 'step_' | append: i | append: '_title'
          assign desc_key = 'step_' | append: i | append: '_description'
          assign step_title = section.settings[title_key]
          assign step_desc = section.settings[desc_key]
        %}
        {% if step_title != blank or step_desc != blank %}
          <div class="awh-step relative" data-animation="block" data-animation-group="{{ section.id }}">
            <div class="awh-step__num">{{ i }}</div>
            {% if step_title != blank %}
              <{{ step_tag }} class="heading {{ section.settings.card_heading_size }} awh-step__title">{{ step_title }}</{{ step_tag }}>
            {% endif %}
            {% if step_desc != blank %}
              <p class="awh-step__desc">{{ step_desc }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.button_text != blank %}
      <div class="awh-cta">
        {% render 'button' %}
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* Vertical/horizontal spacing comes from the theme .section class. */
  .awh-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 56px;
  }

  /* Connector line running behind the number circles (desktop only) */
  .awh-steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: calc(12.5% + 28px);
    right: calc(12.5% + 28px);
    height: 1px;
    background: linear-gradient(90deg, rgb(var(--color-foreground)), rgb(var(--color-foreground) / 0.2), rgb(var(--color-foreground)));
    opacity: 0.3;
    pointer-events: none;
  }

  .awh-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    z-index: 1;
  }

  .awh-step__num {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    /* Opaque (tint layered over the page background) so the connector line
       sits behind the circle and only shows in the gaps between steps. */
    background: linear-gradient(rgb(var(--color-foreground) / 0.12), rgb(var(--color-foreground) / 0.12)), rgb(var(--color-background));
    border: 1px solid rgb(var(--color-foreground) / 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    flex-shrink: 0;
    font-size: var(--size-text-base);
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }

  .awh-step__title {
    margin-bottom: 10px;
    color: rgb(var(--color-foreground));
  }

  .awh-step__desc {
    font-size: var(--size-text-sm);
    line-height: 1.65;
    color: rgb(var(--color-foreground) / 0.65);
    margin: 0;
  }

  .awh-cta {
    display: flex;
    justify-content: center;
    margin-top: 52px;
  }

  @media (max-width: 900px) {
    .awh-steps {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    /* Connector line doesn't make sense once the steps wrap */
    .awh-steps::before { display: none; }
  }

  @media (max-width: 600px) {

    .awh-steps { 
      grid-template-columns: 1fr; 
      gap: 30px;
    }
    awh-cta {   
      margin-top: 30px;
    }
  }
</style>

