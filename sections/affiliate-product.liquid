    }
  ],
  "presets": [
    {
      "name": "Affiliate · Product",
      "category": "Affiliate",
      "blocks": [
        { "type": "feature", "settings": { "text": "Gentle Vibrations" } },
        { "type": "feature", "settings": { "text": "No App Required" } },
        { "type": "feature", "settings": { "text": "14-Day Battery" } },
        { "type": "feature", "settings": { "text": "Water-Resistant" } },
        { "type": "feature", "settings": { "text": "Adjustable Fit" } },
        { "type": "feature", "settings": { "text": "Minimal Design" } },
        { "type": "feature", "settings": { "text": "Build Mindful Habits" } }
