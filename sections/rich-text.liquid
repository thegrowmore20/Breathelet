{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
  }
</style>

<div {% render 'section-attrs' %}>
  <div class="section-body trim-margins {{ section.settings.text_alignment }} max-w-[--content-width]">
    {% render 'rich-text-blocks' %}
  </div>
</div>

{% schema %}
