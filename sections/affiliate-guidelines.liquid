{% render 'affiliate-base' %}
<div class="aff-root"><div class="wrap">
  <div class="section-head reveal"><span class="eyebrow">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2><div class="lead">{{ section.settings.lead }}</div></div>
  <div class="guide">
    <div class="guide-col do reveal"><h3><span class="badge"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>{{ section.settings.do_heading }}</h3>{{ section.settings.do_list }}</div>
    <div class="guide-col dont reveal"><h3><span class="badge"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg></span>{{ section.settings.dont_heading }}</h3>{{ section.settings.dont_list }}</div>
  </div>
  <div class="brand-safe reveal">{{ section.settings.brand_safe }}</div>
</div></div>
{% schema %}
{
  "name": "Affiliate · Guidelines",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Promotion guidelines"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Honest and on-message — always."
    },
    {
      "type": "richtext",
      "id": "lead",
      "label": "Lead",
      "default": "<p>To protect both your credibility and the Breathelet brand.</p>"
    },
    {
      "type": "text",
      "id": "do_heading",
      "label": "Do heading",
      "default": "You're welcome to"
    },
    {
      "type": "richtext",
      "id": "do_list",
      "label": "Do list",
      "default": "<ul><li>Promote on social media platforms</li><li>Share on your website or blog</li><li>Feature it in newsletters and email marketing</li><li>Create authentic content from your real experience</li></ul>"
    },
    {
      "type": "text",
      "id": "dont_heading",
      "label": "Don't heading",
      "default": "Please don't"
    },
    {
      "type": "richtext",
      "id": "dont_list",
      "label": "Don't list",
      "default": "<ul><li>Make medical, health, or therapeutic claims</li><li>Use spam, misleading statements, or false claims</li><li>Create fake urgency or advertise discounts that don't exist</li><li>Run unauthorized paid ads or bid on Breathelet keywords</li></ul>"
    },
    {
      "type": "richtext",
      "id": "brand_safe",
      "label": "Brand-safe messaging",
      "default": "<p><b>Brand-safe messaging.</b> You may use the Breathelet name in your content, as long as you follow our brand guidelines. Position Breathelet as a mindfulness and lifestyle accessory — never as a medical device.</p>"
    }
  ],
  "presets": [
    {
      "name": "Affiliate · Guidelines"
    }
  ]
}
{% endschema %}
