{% render 'affiliate-base' %}
<div class="aff-root support"><div class="wrap">
  <div class="section-head reveal"><span class="eyebrow">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2><div class="lead">{{ section.settings.lead }}</div></div>
  <div class="support-grid">{% for block in section.blocks %}<div class="support-item reveal" {{ block.shopify_attributes }}>{{ block.settings.icon }}<div>{{ block.settings.text }}</div></div>{% endfor %}</div>
</div></div>

{% schema %}
{
  "name": "Affiliate · Support",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Marketing support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We want you to succeed."
    },
    {
      "type": "richtext",
      "id": "lead",
      "label": "Lead",
      "default": "<p>Once approved, just reach out and request:</p>"
    }
  ],
  "blocks": [
    {
      "type": "support_item",
      "name": "Support Item",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icon (SVG)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Support detail</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Affiliate · Support",
      "blocks": [
        {
          "type": "support_item",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><circle cx=\"8.5\" cy=\"8.5\" r=\"1.5\"/><path d=\"M21 15l-5-5L5 21\"/></svg>",
            "text": "<p>Ready-to-use creatives and banners</p>"
          }
        },
        {
          "type": "support_item",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><path d=\"M9 18h6M10 22h4M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2z\"/></svg>",
            "text": "<p>Content ideas and messaging guidance</p>"
          }
        },
        {
          "type": "support_item",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><path d=\"M12 3l7 4v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V7z\"/></svg>",
            "text": "<p>Brand assets and approved talking points</p>"
          }
        },
        {
          "type": "support_item",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><path d=\"M20 12v7a1 1 0 01-1 1H5a1 1 0 01-1-1v-7M2 7h20v5H2zM12 7v13M12 7L8.5 3.5M12 7l3.5-3.5\"/></svg>",
            "text": "<p>Product samples (subject to approval)</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
