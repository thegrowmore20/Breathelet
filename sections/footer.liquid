{% render 'section-bg-number-vars', bg: settings.colors_footer_background %}
{% assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 %}

<style>
  /* ── Background image ── */
  .footer__bg-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .footer__bg-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .footer__bg-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
    pointer-events: none;
  }

  /* ── Content layer ── */
  .footer__content-layer {
    position: relative;
    z-index: 1;
  }

  /* Force the footer to always receive its top spacing.
     --section-has-diff-bg becomes 0 when the footer bg-number matches the
     preceding section, which collapses padding-top to 0. Setting it to 1
     keeps the theme's calc() intact while guaranteeing the spacing applies. */
  #shopify-section-{{ section.id }} .footer {
    --section-has-diff-bg: 1;
  }

  /* ── Contact block ── */
  .contact-info-wrapper {
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 0.75rem !important;
  }

  .contact-info-wrapper .list-contact_item a {
    display: flex !important;
    align-items: flex-start;
    gap: 0.75rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .contact-info-wrapper .list-contact_item svg {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  /* Transition for SVG internals — fill icons (location, email, phone, whatsapp) */
  .contact-info-wrapper .list-contact_item svg .st0 {
    transition: fill 0.2s ease;
  }

  /* Transition for stroke icon (external-link uses stroke attribute on path) */
  .contact-info-wrapper .list-contact_item svg path[stroke] {
    transition: stroke 0.2s ease;
  }

  .contact-info-wrapper .list-contact_item a:hover {
    color: #FBBC05;
  }

  .contact-info-wrapper .list-contact_item a:hover svg {
    transform: scale(1.1);
  }

  /* Fill-based icons: location, email, phone, whatsapp */
  .contact-info-wrapper .list-contact_item a:hover svg .st0 {
    fill: #FBBC05;
  }

  /* Stroke-based icon: external-link */
  .contact-info-wrapper .list-contact_item a:hover svg path[stroke] {
    stroke: #FBBC05;
  }

  /* ── Misc ── */
  .brand-short-brief {
    max-width: 30rem;
    text-align: left;
  }

  /* ── Bottom bar hover effects ── */
  .copyright-block span a {
    transition: color 0.2s ease;
  }

  .copyright-block span a:hover {
    color: #FBBC05;
    text-decoration: underline;
  }

  .privacy-navs a {
    transition: color 0.2s ease;
  }

  .privacy-navs a:hover {
    color: #FBBC05;
    text-decoration: underline;
  }

  .growmore-link {
    transition: color 0.2s ease;
  }

  .growmore-link:hover {
    color: #FBBC05 !important;
  }

  .growmore-link svg {
    transition: transform 0.2s ease;
  }

  .growmore-link:hover svg {
    transform: scale(1.1);
  }

  .growmore-link:hover svg path {
    stroke: #FBBC05;
  }

  .heading-custom {
    font-style: italic;
    font-weight: 500;
    font-family: 'Montserrat';
  }

  /* ── Social icons ── */
  .footer__list-social {
    gap: 0.75rem 1rem;
  }

  .list-social__link {
    transition: color 0.2s ease;
  }

  .list-social__link:hover {
    color: #FBBC05;
  }

  /* ── Mobile layout fixes ── */
  @media (max-width: 767px) {
    /* Smaller payment icons */
    .footer__bottom .payment-icon {
      width: 2rem;
    }

    /* Keep all social icons on one row — no wrapping */
    .footer__list-social {
      flex-wrap: nowrap;
    }

    /* Stack social icons above Follow on Shop button */
    .footer__social-follow-wrap {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    /* Stack copyright line and privacy links on separate rows */
    .footer__bottom-bar {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    /* Keep copyright + GrowMore on one flex row */
    .copyright-block {
      flex-wrap: nowrap;
      justify-content: center;
    }
  }
</style>

<div {% render 'section-attrs', class: 'footer overflow-hidden relative' %}>

  {%- if section.settings.background_image != blank -%}
    <div class="footer__bg-media">
      {{-
        section.settings.background_image
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '800, 1200, 1600, 2000, 2400',
          sizes: '100vw',
          alt: section.settings.background_image.alt | default: 'Footer background'
      -}}
    </div>
  {%- endif -%}

  <div class="footer__content-layer">

    <div class="footer__blocks">
      {% for block in section.blocks %}
        {% case block.type %}

          {% when 'links' %}
            <div
              data-animation="block"
              data-animation-group="{{ section.id }}"
              class="footer-block--links styled-links"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.show_heading %}
                <p class="font-bold mb-4">{{ block.settings.heading | default: block.settings.menu.title }}</p>
              {% endif %}
              <ul class="flex flex-col gap-3">
                {% for link in block.settings.menu.links %}
                  <li><a data-instant href="{{ link.url }}">{{ link.title }}</a></li>
                {% endfor %}
              </ul>

              {% if block.settings.menu_1.links.size > 0 %}
                {% if block.settings.show_heading and block.settings.heading_1 != blank %}
                  <p class="font-bold mt-8 mb-4">{{ block.settings.heading_1 }}</p>
                {% endif %}
                <ul class="flex flex-col gap-3 mt-6">
                  {% for link in block.settings.menu_1.links %}
                    <li><a data-instant href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'text' %}
            <div
              data-animation="block"
              data-animation-group="{{ section.id }}"
              class="footer-block--text"
              {% if block.settings.content_max_width > 0 %}style="max-width: {{ block.settings.content_max_width }}px;"{% endif %}
              {{ block.shopify_attributes }}
            >
              {% if block.settings.image != blank %}
                {%- capture img_sizes -%}min({{ block.settings.image_width }}px, 100vw){%- endcapture -%}
                {%- capture img_style -%}max-width: {{ block.settings.image_width }}px;{%- endcapture -%}
                {% if block.settings.add_url and block.settings.image_url != blank %}
                  <a href="{{ block.settings.image_url }}" class="block mb-6 md:mb-8">
                    {{
                      block.settings.image
                      | image_url: width: 1920
                      | image_tag:
                        class: 'w-full',
                        style: img_style,
                        loading: 'lazy',
                        widths: '120, 270, 420, 570, 720, 870, 1020, 1280',
                        sizes: img_sizes
                    }}
                  </a>
                {% else %}
                  {{
                    block.settings.image
                    | image_url: width: 1920
                    | image_tag:
                      class: 'w-full mb-6 md:mb-8',
                      style: img_style,
                      loading: 'lazy',
                      widths: '120, 270, 420, 570, 720, 870, 1020, 1280',
                      sizes: img_sizes
                  }}
                {% endif %}
              {% endif %}

              {% if block.settings.heading != blank %}
                <p class="font-bold mb-4">{{ block.settings.heading }}</p>
              {% endif %}
              <div class="prose max-md:text-sm">{{ block.settings.content }}</div>
            </div>

          {% when 'newsletter' %}
            <div
              data-animation="block"
              data-animation-group="{{ section.id }}"
              class="footer-block--newsletter"
              {{ block.shopify_attributes }}
            >
              <p class="font-bold mb-4">{{ block.settings.heading }}</p>
              <div class="prose max-md:text-sm">{{ block.settings.content }}</div>
              <div class="flex mt-6">
                {% render 'newsletter-signup-form',
                  button_style: block.settings.button_style,
                  button_text: block.settings.button_text,
                  button_background_color: block.settings.button_background_color,
                  button_text_color: block.settings.button_text_color,
                  button_class: 'text-sm',
                  wrapper_class: 'flex flex-col sm:items-start gap-4'
                %}
              </div>
            </div>

          {% when 'contact' %}
            <div
              data-animation="block"
              data-animation-group="{{ section.id }}"
              class="footer-block--contact"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.heading != blank %}
                <p class="font-bold mb-4 uppercase">{{ block.settings.heading }}</p>
              {% endif %}
              {% render 'contact-info',
                contact_link: block.settings.contact_link_text,
                contact_url: block.settings.contact_url,
                open_new_contact: block.settings.open_new_contact,
                whatsapp_number: block.settings.whatsapp_number,
                whatsapp_url: block.settings.whatsapp_url,
                open_new_whatsapp: block.settings.open_new_whatsapp,
                phone_number: block.settings.phone_number,
                call_url: block.settings.call_url,
                open_new_call: block.settings.open_new_call,
                email_address: block.settings.email_address,
                email_url: block.settings.email_url,
                open_new_email: block.settings.open_new_email,
                location: block.settings.location,
                address_url: block.settings.address_url,
                open_new_address: block.settings.open_new_address
              %}
            </div>

        {% endcase %}
      {% endfor %}
    </div>

    <div class="flex xl:items-center max-xl:flex-col gap-y-8 md:gap-y-12">
      <div class="footer__country-lang flex gap-8 max-xl:justify-center empty:hidden">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          {%- render 'country-selector-dropdown',
            placement: 'top-start',
            flag: section.settings.country_selector_show_country_flag,
            name: section.settings.country_selector_show_country_name,
            currency: section.settings.country_selector_show_currency
          -%}
        {%- endif -%}
        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          {%- render 'language-selector-dropdown', placement: 'top-start' -%}
        {%- endif -%}
      </div>
      <div class="spacer max-xl:hidden"></div>
    </div>

    <div class="footer__bottom items-center justify-between">
      {%- if section.settings.show_payment -%}
        <ul class="flex flex-wrap items-center justify-center gap-2" role="list">
          {% for type in shop.enabled_payment_types %}
            <li>{{ type | payment_type_svg_tag: class: 'payment-icon' }}</li>
          {% endfor %}
        </ul>
      {%- endif -%}
      <div class="flex items-center justify-center gap-2 footer__social-follow-wrap">
        {% if section.settings.show_social %}
          {% render 'footer-social-icons' %}
        {% endif %}
        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
          <div class="text-center xl:text-right xl:ml-6">
            {{ shop | login_button: action: 'follow' }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <hr class="border-separator -mx-co mt-4 mb-4">
    <div class="text-foreground text-sm max-sm:text-xs text-opacity-50 mb-4 flex align-center justify-center gap-3 sm:flex-wrap footer__bottom-bar">
      <div class="styled-links copyright-block flex align-center justify-center gap-1">
        <span>&copy; 2013 - {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}, Developed by</span>
        <a
          target="_blank"
          href="https://thegrowmore.com/"
          class="flex align-center gap-1 powered-by-link text-foreground text-sm max-sm:text-xs text-opacity-50 growmore-link"
        >
          <span class="underline">GrowMore</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="15" viewBox="0 0 16 15" fill="none">
            <path d="M7.99984 2.36898H3.24984C2.82991 2.36898 2.42718 2.53579 2.13025 2.83273C1.83332 3.12966 1.6665 3.53239 1.6665 3.95231V11.869C1.6665 12.2889 1.83332 12.6916 2.13025 12.9886C2.42718 13.2855 2.82991 13.4523 3.24984 13.4523H11.1665C11.5864 13.4523 11.9892 13.2855 12.2861 12.9886C12.583 12.6916 12.7498 12.2889 12.7498 11.869V7.11898M7.20817 7.91064L14.3332 0.785645M14.3332 0.785645H10.3748M14.3332 0.785645V4.74398" stroke="#ffffff80" stroke-width="1.58333" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <nav class="privacy-navs styled-links">
        <ul class="flex align-center gap-2">
          {% for link in linklists.policies.links %}
            <li><a class="text-sm max-sm:text-xs" href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "tag": "footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "info": "Controls the darkness of the overlay on top of the background image",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.footer.settings.full_width.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:sections.footer.settings.show_social.label",
      "info": "t:sections.footer.settings.show_social.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "t:sections.footer.settings.show_payment.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.footer.headers.country_region_selector",
      "info": "To add a country/region, go to your [market settings.](/admin/settings/markets)"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.footer.settings.enable_country_selector.label"
    },
    {
      "type": "checkbox",
      "id": "country_selector_show_country_flag",
      "label": "t:sections.footer.settings.country_selector_show_country_flag.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "country_selector_show_country_name",
      "label": "t:sections.footer.settings.country_selector_show_country_name.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "country_selector_show_currency",
      "label": "t:sections.footer.settings.country_selector_show_currency.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.footer.headers.language_selector",
      "info": "To add a language, go to your [language settings.](/admin/settings/languages)"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "t:sections.footer.settings.enable_language_selector.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.headers.follow_on_shop",
      "info": "To allow customers to follow your store on the Shop app from your storefront, Shop Pay must be enabled. [Learn more](https://help.shopify.com/manual/online-store/themes/customizing-themes/follow-on-shop)"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": true,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "links",
      "name": "t:sections.footer.blocks.links.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_heading",
          "label": "t:sections.footer.blocks.links.settings.show_heading.label",
          "default": true
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.links.settings.heading.label",
          "info": "t:sections.footer.blocks.links.settings.heading.info"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.links.settings.menu.label",
          "info": "t:sections.footer.blocks.links.settings.menu.info",
          "default": "footer"
        },
        {
          "type": "text",
          "id": "heading_1",
          "label": "t:sections.footer.blocks.links.settings.heading.label",
          "info": "t:sections.footer.blocks.links.settings.heading.info"
        },
        {
          "type": "link_list",
          "id": "menu_1",
          "label": "t:sections.footer.blocks.links.settings.menu.label",
          "info": "t:sections.footer.blocks.links.settings.menu.info",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "range",
          "id": "content_max_width",
          "label": "Content max width",
          "info": "Set to 0 to use full available width",
          "min": 0,
          "max": 800,
          "step": 20,
          "unit": "px",
          "default": 0
        },
        {
          "type": "checkbox",
          "id": "add_url",
          "label": "Add link to Image",
          "default": false
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image Link",
          "visible_if": "{{ block.settings.add_url }}"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.footer.blocks.text.settings.content.label",
          "default": "<p>Share contact information, store details, and brand content with your customers.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.footer.blocks.text.settings.image.label"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 60,
          "max": 640,
          "step": 10,
          "unit": "px",
          "label": "t:sections.footer.blocks.text.settings.image_width.label",
          "default": 240
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading.label",
          "default": "Heading"
        },
        {
          "type": "text",
          "id": "contact_link_text",
          "label": "Contact Link",
          "default": "Get In Touch"
        },
        {
          "type": "url",
          "id": "contact_url",
          "label": "Contact URL"
        },
        {
          "type": "checkbox",
          "id": "open_new_contact",
          "label": "Open in New Tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Whatsapp Us"
        },
        {
          "type": "text",
          "label": "Whatsapp Number",
          "id": "whatsapp_number"
        },
        {
          "type": "url",
          "label": "URL",
          "id": "whatsapp_url"
        },
        {
          "type": "checkbox",
          "id": "open_new_whatsapp",
          "label": "Open in New Tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Call Us"
        },
        {
          "type": "text",
          "label": "Phone Number",
          "id": "phone_number"
        },
        {
          "type": "url",
          "label": "URL",
          "id": "call_url"
        },
        {
          "type": "checkbox",
          "id": "open_new_call",
          "label": "Open in New Tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Email Address"
        },
        {
          "type": "text",
          "label": "Email",
          "id": "email_address"
        },
        {
          "type": "url",
          "label": "Link",
          "id": "email_url"
        },
        {
          "type": "checkbox",
          "id": "open_new_email",
          "label": "Open in New Tab",
          "default": false
        },
        {
          "type": "header",
          "content": "Location"
        },
        {
          "type": "text",
          "label": "Address",
          "id": "location"
        },
        {
          "type": "url",
          "label": "Link",
          "id": "address_url"
        },
        {
          "type": "checkbox",
          "id": "open_new_address",
          "label": "Open in New Tab",
          "default": false
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.newsletter.settings.heading.label",
          "default": "Stay in touch"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.footer.blocks.newsletter.settings.content.label",
          "default": "<p>Provide additional information about your newsletter and explain the benefits of subscribing to it.</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "default": "Subscribe",
          "label": "t:sections.footer.blocks.newsletter.settings.button_text.label"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:sections.all.button_style.label",
          "options": [
            {
              "value": "",
              "label": "t:sections.all.button_style.options.filled"
            },
            {
              "value": "button-outline",
              "label": "t:sections.all.button_style.options.outline"
            }
          ],
          "default": ""
        },
        {
          "type": "header",
          "content": "t:sections.all.headers.colors"
        },
        {
          "type": "color",
          "label": "t:sections.all.button_background_color.label",
          "id": "button_background_color"
        },
        {
          "type": "color",
          "label": "t:sections.all.button_text_color.label",
          "id": "button_text_color"
        }
      ]
    }
  ]
}
{% endschema %}
