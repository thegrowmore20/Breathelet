    },
    {
      "type": "color",
      "label": "t:sections.all.heading_color.label",
      "id": "heading_color"
    }
  ],
"blocks": [
    {
        "type" : "@app"
    },
    {
        "type" : "@theme"
    }
  ],
    "presets": [
        {
            "name": "Custom Section",
        }
    ]
}
{% endschema %}