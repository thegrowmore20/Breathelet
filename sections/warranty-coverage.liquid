{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
    --bc-accent: {{ section.settings.accent_color }};
    --bc-accent-rgb: {{ section.settings.accent_color.red }} {{ section.settings.accent_color.green }} {{ section.settings.accent_color.blue }};
  }
</style>

{% liquid
  assign section_classes = ''

  if section.settings.remove_horizontal_space
    assign section_classes = section_classes | append: ' !px-0 '
  endif

  if section.settings.remove_vertical_space
    assign section_classes = section_classes | append: ' !py-0 '
  endif

  if section.settings.link_url != blank
    assign link_url = section.settings.link_url
  else
    assign link_url = null
  endif

  assign card_tag = section.settings.card_heading_html_tag | default: 'h3'
%}

<section {% render 'section-attrs', class: section_classes %}>
  <div class="section-body">
    <div class="max-w-[--content-width] mx-auto">
      {% render 'section-header', link_text: section.settings.link_text, link_url: link_url, new_tab: section.settings.new_tab %}

      <div class="bc-coverage-grid" data-animation-auto-order>

        <!-- COVERED CARD -->
        <div class="bc-coverage-card bc-covered" data-animation="block" data-animation-group="{{ section.id }}">
          <div class="bc-card-title">
            <div class="bc-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </div>
            <{{ card_tag }} class="heading {{ section.settings.card_heading_size }} bc-card-heading">{{ section.settings.covered_heading }}</{{ card_tag }}>
          </div>

          <ul class="bc-coverage-list">
            {% if section.settings.covered_item_1 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.covered_item_1 }}</li>
            {% endif %}
            {% if section.settings.covered_item_2 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.covered_item_2 }}</li>
            {% endif %}
            {% if section.settings.covered_item_3 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.covered_item_3 }}</li>
            {% endif %}
            {% if section.settings.covered_item_4 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.covered_item_4 }}</li>
            {% endif %}
          </ul>
        </div>

        <!-- NOT COVERED CARD -->
        <div class="bc-coverage-card bc-not-covered" data-animation="block" data-animation-group="{{ section.id }}">
          <div class="bc-card-title">
            <div class="bc-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" y1="9" x2="9" y2="15"/>
                <line x1="9"  y1="9" x2="15" y2="15"/>
              </svg>
            </div>
            <{{ card_tag }} class="heading {{ section.settings.card_heading_size }} bc-card-heading">{{ section.settings.not_covered_heading }}</{{ card_tag }}>
          </div>

          <ul class="bc-coverage-list">
            {% if section.settings.not_covered_item_1 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.not_covered_item_1 }}</li>
            {% endif %}
            {% if section.settings.not_covered_item_2 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.not_covered_item_2 }}</li>
            {% endif %}
            {% if section.settings.not_covered_item_3 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.not_covered_item_3 }}</li>
            {% endif %}
            {% if section.settings.not_covered_item_4 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.not_covered_item_4 }}</li>
            {% endif %}
            {% if section.settings.not_covered_item_5 != blank %}
              <li><span class="bc-dot"></span>{{ section.settings.not_covered_item_5 }}</li>
            {% endif %}
          </ul>
        </div>

      </div>

      {% if section.settings.footer_text != blank %}
        <div class="bc-footer" data-animation="block" data-animation-group="{{ section.id }}">
          {{ section.settings.footer_text }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  /* ── BREATHELET COVERAGE – scoped with bc- prefix ── */
  .bc-coverage-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  /* ── FOOTER CALLOUT ── */
  .bc-footer {
    margin-top: 24px;
    padding: 24px 32px;
    border-radius: 16px;
    background: rgb(var(--color-foreground) / 0.04);
    border: 1px solid rgb(var(--color-foreground) / 0.08);
    font-size: var(--size-text-sm);
    line-height: 1.75;
    color: rgb(var(--color-foreground) / 0.65);
    text-align: left;
  }

  /* ── CARDS ── */
  .bc-coverage-card {
    background: rgb(var(--color-foreground) / 0.04);
    border: 1px solid rgb(var(--color-foreground) / 0.08);
    border-radius: 16px;
    padding: 40px;
    text-align: left;
  }

  /* ── CARD TITLE ROW ── */
  .bc-card-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .bc-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bc-icon-wrap svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Covered – white tones */
  .bc-covered .bc-icon-wrap {
    background: rgb(var(--color-foreground) / 0.12);
  }

  .bc-covered .bc-icon-wrap svg {
    stroke: rgb(var(--color-foreground));
  }

  /* Not Covered – muted tones */
  .bc-not-covered .bc-icon-wrap {
    background: rgb(var(--color-foreground) / 0.06);
  }

  .bc-not-covered .bc-icon-wrap svg {
    stroke: rgb(var(--color-foreground) / 0.45);
  }

  .bc-card-heading {
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  /* ── LIST ── */
  .bc-coverage-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .bc-coverage-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 11px 0;
    font-size: var(--size-text-sm);
    color: rgb(var(--color-foreground) / 0.8);
    border-bottom: 1px solid rgb(var(--color-foreground) / 0.08);
    line-height: 1.5;
  }

  .bc-coverage-list li:last-child {
    border-bottom: none;
  }

  /* ── DOT ── */
  .bc-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .bc-covered .bc-dot {
    background: rgb(var(--color-foreground));
  }

  .bc-not-covered .bc-dot {
    background: rgb(var(--color-foreground) / 0.45);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .bc-coverage-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .bc-coverage-card {
      padding: 32px 24px;
    }
  }
</style>

