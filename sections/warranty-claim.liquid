{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
  }
</style>

{% liquid
  assign section_classes = ''

  if section.settings.remove_horizontal_space
    assign section_classes = section_classes | append: ' !px-0 '
  endif

  if section.settings.remove_vertical_space
    assign section_classes = section_classes | append: ' !py-0 '
  endif

  if section.settings.link_url != blank
    assign link_url = section.settings.link_url
  else
    assign link_url = null
  endif

  assign card_tag = section.settings.card_heading_html_tag | default: 'h3'
%}

<section {% render 'section-attrs', class: section_classes %}>
  <div class="section-body">
    <div class="max-w-[--content-width] mx-auto">
      {% render 'section-header', link_text: section.settings.link_text, link_url: link_url, new_tab: section.settings.new_tab, button: false %}

      <div class="bcl-steps-grid" data-animation-auto-order>

        <!-- STEP 1 -->
        <div class="bcl-step-card" data-animation="block" data-animation-group="{{ section.id }}">
          <div class="bcl-step-number">1</div>
          <{{ card_tag }} class="heading {{ section.settings.card_heading_size }} bcl-step-title">{{ section.settings.step_1_title }}</{{ card_tag }}>
          <p class="bcl-step-desc">{{ section.settings.step_1_description }}</p>
        </div>

        <!-- STEP 2 -->
        <div class="bcl-step-card" data-animation="block" data-animation-group="{{ section.id }}">
          <div class="bcl-step-number">2</div>
          <{{ card_tag }} class="heading {{ section.settings.card_heading_size }} bcl-step-title">{{ section.settings.step_2_title }}</{{ card_tag }}>
          <p class="bcl-step-desc">{{ section.settings.step_2_description }}</p>
        </div>

        <!-- STEP 3 -->
        <div class="bcl-step-card" data-animation="block" data-animation-group="{{ section.id }}">
          <div class="bcl-step-number">3</div>
          <{{ card_tag }} class="heading {{ section.settings.card_heading_size }} bcl-step-title">{{ section.settings.step_3_title }}</{{ card_tag }}>
          <p class="bcl-step-desc">{{ section.settings.step_3_description }}</p>
        </div>

      </div>

      <!-- OPTIONAL CTA BUTTON -->
      {% if section.settings.button_text != blank %}
        <div class="bcl-cta-wrap">
          {% render 'button' %}
        </div>
      {% endif %}

    </div>
  </div>
</section>

<style>
  /* ── BREATHELET CLAIM – scoped with bcl- prefix ── */
  .bcl-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    position: relative;
  }

  /* Connector line between cards (desktop only) */
  .bcl-steps-grid::before {
    content: '';
    position: absolute;
    top: 36px;
    left: calc(16.67% + 28px);
    right: calc(16.67% + 28px);
    height: 1px;
    background: linear-gradient(90deg, rgb(var(--color-foreground)), rgb(var(--color-foreground) / 0.2), rgb(var(--color-foreground)));
    opacity: 0.3;
    pointer-events: none;
  }

  /* ── STEP CARD ── */
  .bcl-step-card {
    /* opaque card (tint layered over the theme background) so the
       connector line sits behind the cards and only shows in the gaps */
    background: linear-gradient(rgb(var(--color-foreground) / 0.04), rgb(var(--color-foreground) / 0.04)), rgb(var(--color-background));
    border: 1px solid rgb(var(--color-foreground) / 0.08);
    border-radius: 16px;
    padding: 36px 28px;
    text-align: center;
    position: relative;
    z-index: 1;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .bcl-step-card:hover {
    border-color: rgb(var(--color-foreground) / 0.3);
    transform: translateY(-4px);
  }

  /* ── STEP NUMBER CIRCLE (white contrast, page-faqs format) ── */
  .bcl-step-number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgb(var(--color-foreground) / 0.12);
    border: 1px solid rgb(var(--color-foreground) / 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 22px;
    font-size: var(--size-text-lg);
    font-weight: 700;
    color: rgb(var(--color-foreground));
    font-family: inherit;
  }

  /* ── STEP TITLE ── */
  .bcl-step-title {
    color: rgb(var(--color-foreground));
    margin-bottom: 10px;
  }

  /* ── STEP DESCRIPTION ── */
  .bcl-step-desc {
    font-size: var(--size-text-sm);
    color: rgb(var(--color-foreground) / 0.6);
    line-height: 1.7;
    margin: 0;
  }

  /* ── OPTIONAL CTA ── */
  .bcl-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .bcl-steps-grid {
      grid-template-columns: 1fr;
    }

    /* Hide connector line on mobile — doesn't make sense stacked */
    .bcl-steps-grid::before {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .bcl-step-card {
      padding: 32px 24px;
    }
  }
</style>

