{% render 'section-bg-number-vars' %}

<style>
	#shopify-section-{{ section.id }} {
		--content-width: {% render 'get-content-width', type: section.settings.content_width %};
	}
</style>
<section {% render 'section-attrs' %}>
	<div class="section-body trim-margins">
		<div class="services-container {% if section.settings.vertical_layout %}services-vertical-layout text-center{% endif %}" style="background-color: {{ section.settings.bg_color }};">
			<div class="services-intro {% if section.settings.show_divider %}has-divider{% endif %}">
				<h2 class="uppercase">{{ section.settings.heading | escape }}</h2>
				{% if section.settings.text_1 != blank %}
					<p>{{ section.settings.text_1 }}</p>
				{% endif %}
				<div class="intro-images">
					{% if section.settings.intro_img_1 != blank %}
						<div class="service-intro-main intro-main-image-1">
						{{
							section.settings.intro_img_1
							| image_url: width: 280
							| image_tag:
								widths: '140, 280, 420, 560',
								sizes: '(max-width: 480px) 140px, (max-width: 768px) 280px, 280px',
								width: 280,
								height: 280,
								alt: section.settings.intro_img_1.alt,
								loading: 'lazy'
						}}
						{% if section.settings.intro_text_1 != blank %}
							<h3 class="mt-3 font-bold"> {{ section.settings.intro_text_1 }}  </h3>
						{% endif %}
					</div>
					{% elsif section.settings.intro_img_url_1 != blank %}
						<img src="{{ section.settings.intro_img_url_1 }}" alt="Intro image" loading="lazy" width="280" height="auto">
					{% endif %}
					{% if section.settings.intro_img_2 != blank %}
						<div class="service-intro-main intro-main-image-2">
						{{
							section.settings.intro_img_2
							| image_url: width: 280
							| image_tag:
								widths: '140, 280, 420, 560',
								sizes: '(max-width: 480px) 140px, (max-width: 768px) 280px, 280px',
								width: 280,
								height: 280,
								alt: section.settings.intro_img_2.alt,
								loading: 'lazy'
						}}
						{% if section.settings.intro_text_2 != blank %}
							<h3 class="mt-3 font-bold"> {{ section.settings.intro_text_2 }}  </h3>
						{% endif %}
					</div>
					{% elsif section.settings.intro_img_url_2 != blank %}
						<img src="{{ section.settings.intro_img_url_2 }}" alt="Intro image" loading="lazy" width="280" height="auto">
					{% endif %}
				</div>
					</div>
					<div class="services-grid">
						{% for block in section.blocks %}
							<div class="service-card" {{ block.shopify_attributes }}>
								{% if block.settings.icon_html != blank %}
									<div class="service-icon">
										{{ block.settings.icon_html }}
									</div>
								{% elsif block.settings.icon_image != blank %}
									<div class="service-icon">										
										{{
											block.settings.icon_image
											| image_url: width: 88
											| image_tag:
												widths: '44, 88, 132',
												sizes: '88px',
												width: 88,
												height: 88,
												alt: block.settings.icon_image.alt,
												loading: 'lazy'
											}}

										</div>
									{% endif %}
									
									<h3>{{ block.settings.title | escape }}</h3>
									<p>{{ block.settings.text }}</p>
									
									{% if block.settings.link_label != blank and block.settings.link_url != blank %}
										<a href="{{ block.settings.link_url }}" class="service-link" style="color: {{ section.settings.link_color }};">{{ block.settings.link_label | escape }}</a>
									{% endif %}
								</div>
							{% endfor %}
						</div>
					</div>
				</div>
			</section>
			<style>
				/* CSS adapted for section id wrapper to prevent conflicts */
				#shopify-section-{{ section.id }} .services-container {
					color: #ffffff;
					width: 100%;
					border-radius: 8px;
					display: flex;
					gap: 80px;
				}

				#shopify-section-{{ section.id }} .services-container.services-vertical-layout {
					flex-direction: column;
					gap: 50px;
				}

				#shopify-section-{{ section.id }} .services-intro {
					flex: 0 0 35%;
					display: flex;
					flex-direction: column;
					position: relative;
					border: 1px solid;
					border-radius: 12px;
					padding: 2rem;
					box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
				}
				#shopify-section-{{ section.id }} .services-intro.has-divider::after {
					content: '';
					position: absolute;
					right: -40px;
					top: 0;
					bottom: 0;
					width: 1px;
					background-color: rgba(255, 255, 255, 0.2);
				}
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-intro.has-divider::after {
					width: 100%;
					height: 1px;
					top: auto;
					bottom: -30px;
					right: 0;
					left: 0;
				}
				#shopify-section-{{ section.id }} .services-intro h2 {
					font-size: 2.2rem;
					line-height: 1.25;
					margin-bottom: 24px;					;
					color: #ffffff;
				}
				#shopify-section-{{ section.id }} .services-intro p {
					font-size: 1rem;
					line-height: 1.6;
					margin-bottom: 24px;
					color: #e0e0e0;
				}
				#shopify-section-{{ section.id }} .intro-images {
					display: flex;
					flex-wrap: wrap;
					gap: 20px;
					margin-top: 16px;
					justify-content: center;
					align-items: center;
				}
				#shopify-section-{{ section.id }} .intro-images img {
					max-width: 180px;
					height: auto;
					object-fit: contain;
				}
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .intro-images img {
					max-width: 150px;
					margin-left: auto;
					margin-right: auto;
				}
				#shopify-section-{{ section.id }} .services-grid {
					flex: 1;
					display: grid;
					grid-template-columns: repeat(2, 1fr);
					grid-row-gap: 25px;
					grid-column-gap: 25px;
				}
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
					grid-template-columns: repeat(4, 1fr);
				}
				#shopify-section-{{ section.id }} .service-card {
					display: flex;
					flex-direction: column;
					background-color: #202020;
					padding: 2rem 1rem;		
					border-radius: 12px;	
				}
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card {
					align-items: center;
				}
				#shopify-section-{{ section.id }} .service-icon {
					width: 68px;
					height: 68px;
					margin-bottom: 20px;
					display: flex;
					align-items: center;
					justify-content: center;
					color: #ffffff;
				}
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon {
					width: 80px;
					height: 80px;
					margin-bottom: 20px;
				}
				#shopify-section-{{ section.id }} .service-icon > svg,
				#shopify-section-{{ section.id }} .service-icon > img {
					width: 50px;
					height: 50px;
					object-fit: contain;
				}
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > svg,
				#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > img {
					width: 60px;
					height: 60px;
					object-fit: contain;
				}
				#shopify-section-{{ section.id }} .service-card h3 {
					font-size: 1.3rem;
					margin-bottom: 12px;
					font-weight: 600;
					    margin-bottom: .5rem;
					color: #ffffff;
				}
				#shopify-section-{{ section.id }} .service-card p {
					font-size: 0.95rem;
					line-height: 1.6;
					color: #e0e0e0;
					margin-bottom: 16px;
					flex-grow: 1;
					margin-bottom: 0;
				}
				#shopify-section-{{ section.id }} .service-link {
					text-decoration: none;
					font-weight: 500;
					font-size: 0.95rem;
				}
				#shopify-section-{{ section.id }} .service-link:hover {
					text-decoration: underline;
				}
				@media screen and (max-width: 992px) {
					#shopify-section-{{ section.id }} .services-container {
						flex-direction: column;
						padding: 40px;
						gap: 50px;
					}
					#shopify-section-{{ section.id }} .services-intro {
						flex: auto;
					}
					#shopify-section-{{ section.id }} .services-intro.has-divider::after {
						display: none;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-intro.has-divider::after {
						display: block;
					}
				}
				
				@media screen and (max-width: 992px) {
					#shopify-section-{{ section.id }} .services-grid {
						grid-template-columns: 1fr 1fr;
						grid-row-gap: 20px;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
						grid-template-columns: repeat(2, 1fr);
					}
					#shopify-section-{{ section.id }} .intro-images img {
						max-width: min(20%, 150px);
						margin-left: auto;
						margin-right: auto;
					}
					#shopify-section-{{ section.id }} .intro-images {
						flex-wrap: nowrap;
						justify-content: center;
						align-items: center;
					}
					
					
					#shopify-section-{{ section.id }} .services-container{
						padding: 0;
					}
					
				}
				@media screen and (max-width: 767px) {
					#shopify-section-{{ section.id }} .services-grid {
						grid-template-columns: 1fr;
						grid-row-gap: 20px;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
						grid-template-columns: repeat(2, 1fr);
						column-gap: 15px
					}
					
					#shopify-section-{{ section.id }} .intro-images {        
						justify-content: flex-start;        
					}
					
					#shopify-section-{{ section.id }} .intro-images img {
						max-width: min(45%, 150px);
						margin-left: auto;
						margin-right: auto;
					}

					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .intro-images img {
						max-width: min(calc(70% - 10px), 150px);
						margin-left: auto;
						margin-right: auto;
					}
					
					#shopify-section-{{ section.id }} .services-container{
						padding: 10px 0;
						gap: 40px;
					}
					#shopify-section-{{ section.id }} .services-intro h2 {
						font-size: 1.9rem;
					}
					
					#shopify-section-{{ section.id }} .service-card{
						align-items: center;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card h3 {
						font-size: .8rem;
						margin-bottom: .2rem;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon {
						width: 50px;
						height: 50px;
						margin-bottom: 20px;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > svg,
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-icon > img {
						width: 40px;
						height: 40px;
					}
				}
				@media screen and (max-width: 520px) {
					#shopify-section-{{ section.id }} .services-intro {
						padding: 1rem
					}
					#shopify-section-{{ section.id }} .services-intro h2 {
						font-size: 1.6rem;
						margin-bottom: .5rem;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout {
						gap: 25px;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .services-grid {
						gap: 8px;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card {
						padding: 1rem .5rem;
					}
					#shopify-section-{{ section.id }} .services-container.services-vertical-layout .service-card p {
						font-size: 10px;						
					}
					#shopify-section-{{ section.id }} .services-intro p {
						margin-bottom: .5rem;						
					}
				}
			</style>
			{% schema %}
			{
				"name": "General USPs",
				"settings": [
					{
						"type": "checkbox",
						"id": "full_width",
						"label": "t:sections.all.full_width.label",
						"default": true
					},
					{
						"type": "color",
						"id": "bg_color",
						"label": "Container Background Color",
						"default": "#333333"
					},
					{
						"id": "vertical_layout",
						"type": "checkbox",
						"label": "Vertical Layout"
					},
					{
						"type": "checkbox",
						"id": "show_divider",
						"label": "Show Vertical Divider",
						"default": true
					},
					{
						"type": "text",
						"id": "heading",
						"label": "Heading",
						"default": "Premium Assurance with Lifetime Support"
					},
					{
						"type": "textarea",
						"id": "text_1",
						"label": "Paragraph",
						"default": "Enjoy peace of mind with our 30-day money-back guarantee and a lifetime warranty, proving our commitment to high-quality, trusted products since 2013."
					},
					{
						"type": "image_picker",
						"id": "intro_img_1",
						"label": "First Intro Image"
					},
					{
						"type": "text",
						"id": "intro_text_1",
						"label": "First Image Text",
						"default": "LIFETIME WARRANTY"
					},
					{
						"type": "image_picker",
						"id": "intro_img_2",
						"label": "Second Intro Image"
					},
					{
						"type": "text",
						"id": "intro_text_2",
						"label": "First Image Text",
						"default": "30 DAYS GUARANTEE"
					},
					{
						"type": "text",
						"id": "intro_img_url_1",
						"label": "First Intro Image URL (overridden by picker above)",
						"default": "https://airvapeusa.com/cdn/shop/files/icon_Warranty_3.svg?v=1774515664"
					},
					{
						"type": "text",
						"id": "intro_img_url_2",
						"label": "Second Intro Image URL (overridden by picker above)",
						"default": "https://airvapeusa.com/cdn/shop/files/icon_MoneyBack_Gurantee_3.svg?v=1774515656"
					},
					{
						"type": "color",
						"id": "link_color",
						"label": "Service Link Color",
						"default": "#ffd814"
					},
					{
						"type": "header",
						"content": "t:sections.all.headers.colors"
					},
					{
						"type": "color",
						"label": "t:sections.all.background_color.label",
						"id": "background_color"
					},
					{
						"type": "color",
						"label": "t:sections.all.text_color.label",
						"id": "text_color"
					},
					{
						"type": "color",
						"label": "t:sections.all.heading_color.label",
						"id": "heading_color"
					},
					{
						"type": "header",
						"content": "t:sections.all.headers.seo"
					},
					{
						"type": "select",
						"id": "heading_html_tag",
						"label": "t:sections.all.heading_html_tag.label",
						"options": [
							{
								"value": "h1",
								"label": "h1"
							},
							{
								"value": "h2",
								"label": "h2"
							},
							{
								"value": "h3",
								"label": "h3"
							},
							{
								"value": "h4",
								"label": "h4"
							},
							{
								"value": "h5",
								"label": "h5"
							},
							{
								"value": "h6",
								"label": "h6"
							},
							{
								"value": "p",
								"label": "p"
							},
							{
								"value": "span",
								"label": "span"
							},
							{
								"value": "div",
								"label": "div"
							}
						],
						"default": "p",
						"info": "t:sections.all.heading_html_tag.info"
					}
				],
				"blocks": [
					{
						"type": "service",
						"name": "Service Item",
						"limit": 6,
						"settings": [
							{
								"type": "html",
								"id": "icon_html",
								"label": "Icon HTML (SVG)"
							},
							{
								"type": "image_picker",
								"id": "icon_image",
								"label": "Icon Image (if SVG is blank)"
							},
							{
								"type": "text",
								"id": "title",
								"label": "Title",
								"default": "Service Name"
							},
							{
								"type": "textarea",
								"id": "text",
								"label": "Description",
								"default": "Describe your service here."
							},
							{
								"type": "text",
								"id": "link_label",
								"label": "Link Label",
								"default": "More about this service"
							},
							{
								"type": "url",
								"id": "link_url",
								"label": "Link URL"
							}
						]
					}
				],
				"presets": [
					{
						"name": "General USPs",
						"category": "Custom Sections",
						"blocks": [
							{
								"type": "service",
								"settings": {
									"title": "FAST HEAT-UP",
									"text": "Ready to go in seconds",
									"link_label": ""
								}
							},
							{
								"type": "service",
								"settings": {
									"title": "PURE FLAVOUR",
									"text": "Crisp vapor with precision",
									"link_label": ""
								}
							},
							{
								"type": "service",
								"settings": {
									"title": "EASY TO USE",
									"text": "Effortless enjoyment",
									"link_label": ""
								}
							},
							{
								"type": "service",
								"settings": {
									"title": "LONG BATTERY LIFE",
									"text": "Enjoy more sessions",
									"link_label": ""
								}
							}
						]
					}
				]
			}
			{% endschema %}