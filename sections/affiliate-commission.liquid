{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
    --acm-accent: {{ section.settings.accent_color }};
    --acm-accent-rgb: {{ section.settings.accent_color.red }} {{ section.settings.accent_color.green }} {{ section.settings.accent_color.blue }};
  }
</style>

{% liquid
  assign section_classes = ' acm-section '

  if section.settings.remove_horizontal_space
    assign section_classes = section_classes | append: ' !px-0 '
  endif

  if section.settings.remove_vertical_space
    assign section_classes = section_classes | append: ' !py-0 '
  endif

  assign card_tag = section.settings.card_heading_html_tag | default: 'h3'
%}

<section {% render 'section-attrs', class: section_classes %}>
  <div class="section-body max-w-[--content-width] mx-auto">

    {% render 'section-header' %}

    {% if section.blocks.size > 0 %}
      <div class="acm-grid" data-animation-auto-order>
        {% for block in section.blocks %}
          <article
            class="acm-card{% if block.settings.highlight %} acm-card--highlight{% endif %}"
            data-animation="block"
            data-animation-group="{{ section.id }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.icon_image != blank %}
              {% assign icon_sizes = block.settings.icon_width | append: 'px' %}
              <div class="acm-card__icon" style="width: {{ block.settings.icon_width }}px;">
                {{
                  block.settings.icon_image
                  | image_url: width: 176
                  | image_tag:
                    widths: '44, 88, 132, 176',
                    sizes: icon_sizes,
                    alt: block.settings.icon_image.alt,
                    loading: 'lazy'
                }}
              </div>
            {% endif %}

            {% if block.settings.title != blank %}
              <{{ card_tag }} class="heading {{ section.settings.card_heading_size }} acm-card__title">{{ block.settings.title }}</{{ card_tag }}>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="acm-card__desc">{{ block.settings.text }}</div>
            {% endif %}

            {% if block.settings.methods != blank %}
              <div class="acm-card__methods">
                {% assign methods = block.settings.methods | split: ',' %}
                {% for method in methods %}
                  <span class="acm-method">{{ method | strip }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* Vertical/horizontal spacing comes from the theme .section class. */
  .acm-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;    
    text-align: left;
  }

  .acm-card {
    padding: 32px 28px;
    border-radius: 16px;
    background: rgb(var(--color-foreground) / 0.07);
    border: 1px solid rgb(var(--color-foreground) / 0.12);
  }

  .acm-card--highlight {
    background: rgb(var(--acm-accent-rgb) / 0.07);
    border-color: rgb(var(--acm-accent-rgb) / 0.25);
  }

  .acm-card__icon {
    margin-bottom: 14px;
    max-width: 100%;
  }

  .acm-card__icon img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .acm-card__title {
    margin-bottom: 10px;
    color: rgb(var(--color-foreground));
  }

  .acm-card__desc {
    font-size: var(--size-text-sm);
    line-height: 1.7;
    color: rgb(var(--color-foreground) / 0.65);
  }

  .acm-card__methods {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .acm-method {
    padding: 5px 12px;
    border-radius: 8px;
    background: rgb(var(--color-foreground) / 0.07);
    border: 1px solid rgb(var(--color-foreground) / 0.12);
    font-size: var(--size-text-xs);
    font-weight: 500;
    color: rgb(var(--color-foreground) / 0.8);
  }

  /* Center a lone card on the last row (e.g. a 5th card in a 2-col grid) */
  @media (min-width: 901px) {
    .acm-card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      max-width: calc(50% - 10px);
      margin-inline: auto;
    }
  }

  @media (max-width: 900px) {
    .acm-grid { grid-template-columns: 1fr; }
  }
</style>

