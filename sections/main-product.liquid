<style>
  {% if section.settings.background_color != blank and section.settings.background_color.rgba != '0 0 0 / 0.0' %}
    .product-grid {
      background: {{ section.settings.background_color }};
    }
  {% endif %}

  .section-main-product + .section-main-product-details {
    {% if section.settings.text_color != blank and section.settings.text_color.rgba != '0 0 0 / 0.0' %}
      --color-foreground: {{ section.settings.text_color.rgb }};
    {% endif %}
  }

  .section-main-product + .section-main-product-details + * {
    --previous-section-bg-number: {% render 'get-bg-number' %};
  }

  #shopify-section-{{ section.id }} {
    {% render 'apply-color-vars',
      background: section.settings.background_color,
      text: section.settings.text_color,
      heading: section.settings.heading_color
    %}
  }

  .hooktext .metafield-rich_text_field p:first-of-type {
    margin-bottom: 0;
}

.hooktext .metafield-rich_text_field p:last-of-type {
    margin-top: .5rem;
}
@media (max-width: 520px) {
    .section-main-product .icon-text-block--inline {
      gap: 5px;
      grid-template-columns: repeat(4, 1fr);
    }
    
    
    .section-main-product .icon-text-block--inline .icon-wrapper img{
      width: 50px !important;    
    }
    .icon-text-block--vertical.homepage-usps-info .icon-wrapper img{
      width: 40px !important;        
    }
    .icon-text-block--vertical.homepage-usps-info .icon-wrapper{        
      padding: 5px;
    }
    
    .icon-text-block--vertical.homepage-usps-info .icon-text,
    .section-main-product .icon-text-block--inline .icon-text {
      font-size: 12px !important;
      line-height: normal;
    }
    
    .product-info-inner .product-rich-text .prose .metafield-rich_text_field :where(h4):not(:where([class~=not-prose],[class~=not-prose] *)){
      font-size: 1rem;
    }
    .rez-stock-notification-button {   
      margin-top: 0rem !important; 
      padding: 8px 20px !important;
    }
    
  }
</style>

<div style="display: none">media-size{{ section.settings.media_size }}</div>

{% render 'section-bg-number-vars' %}
{% render 'product-media', section: section %}
{% render 'product-info' %}
{% if section.settings.show_sticky_add_to_cart %}
  {% render 'product-sticky-add-to-cart' %}
{% endif %}
{% render 'product-rich-snippets' %}


<script>
  (function () {
  function getVariantId() {
    const p = new URLSearchParams(location.search).get('id');
    if (p) return p;
    const input = document.querySelector('[name="id"]');
    return input ? input.value : null;
  }

  function swap(variantId) {
    document.querySelectorAll('[data-collapsible-data]').forEach(function (store) {
      const id = store.getAttribute('data-collapsible-data');
      const target = document.querySelector('[data-collapsible-target="' + id + '"]');
      if (!target) return;

      let tpl = variantId && store.querySelector('template[data-variant-id="' + variantId + '"]');
      if (!tpl) tpl = store.querySelector('template[data-default]');
      if (tpl && target.innerHTML !== tpl.innerHTML) {
        target.innerHTML = tpl.innerHTML;
        // smooth-collapse caches height — nudge it to recalc if open
        const wrapper = store.closest('smooth-collapse');
        if (wrapper) wrapper.dispatchEvent(new Event('resize'));
      }
    });
  }

  // --- INTEGRATION POINT: your theme's variant change event ---
  // Dawn-style pub/sub
  if (window.subscribe && window.PUB_SUB_EVENTS) {
    subscribe(PUB_SUB_EVENTS.variantChange, function (e) {
      if (e.data && e.data.variant) swap(e.data.variant.id);
    });
  }
  // Custom-event themes
  document.addEventListener('variant:change', function (e) {
    swap((e.detail && e.detail.variant && e.detail.variant.id) || getVariantId());
  });
  // Generic fallback: the hidden variant id input
  document.addEventListener('change', function (e) {
    if (e.target && e.target.name === 'id') swap(e.target.value);
  });

  document.addEventListener('DOMContentLoaded', function () { swap(getVariantId()); });
})();
</script>

