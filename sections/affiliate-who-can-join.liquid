{% render 'section-bg-number-vars' %}

<style>
  #shopify-section-{{ section.id }} {
    --content-width: {% render 'get-content-width', type: section.settings.content_width %};
    --awc-accent: {{ section.settings.accent_color }};
    --awc-accent-rgb: {{ section.settings.accent_color.red }} {{ section.settings.accent_color.green }} {{ section.settings.accent_color.blue }};
  }
</style>

{% liquid
  assign section_classes = ' awc-section '

  if section.settings.remove_horizontal_space
    assign section_classes = section_classes | append: ' !px-0 '
  endif

  if section.settings.remove_vertical_space
    assign section_classes = section_classes | append: ' !py-0 '
  endif

  assign item_tag = section.settings.card_heading_html_tag | default: 'h3'
  assign note_tag = section.settings.note_heading_html_tag | default: 'h3'
%}

<section {% render 'section-attrs', class: section_classes %}>
  <div class="section-body max-w-[--content-width] mx-auto">

    {% render 'section-header', button: false %}

    <div class="awc-grid">
      {% if section.blocks.size > 0 %}
        <div class="awc-list" data-animation-auto-order>
          {% for block in section.blocks %}
            <article
              class="awc-item"
              data-animation="block"
              data-animation-group="{{ section.id }}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.icon_image != blank %}
                {% assign icon_sizes = block.settings.icon_width | append: 'px' %}
                <div class="awc-item__icon" style="width: {{ block.settings.icon_width }}px;">
                  {{
                    block.settings.icon_image
                    | image_url: width: 176
                    | image_tag:
                      widths: '44, 88, 132, 176',
                      sizes: icon_sizes,
                      alt: block.settings.icon_image.alt,
                      loading: 'lazy'
                  }}
                </div>
              {% endif %}
              <div class="awc-item__body">
                {% if block.settings.title != blank %}
                  <{{ item_tag }} class="heading {{ section.settings.card_heading_size }} awc-item__title">{{ block.settings.title }}</{{ item_tag }}>
                {% endif %}
                {% if block.settings.text != blank %}
                  <div class="awc-item__text">{{ block.settings.text }}</div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.note_heading != blank or section.settings.note_text != blank or section.settings.button_text != blank %}
        <aside class="awc-note" data-animation="block" data-animation-group="{{ section.id }}">
          {% if section.settings.note_heading != blank %}
            <{{ note_tag }} class="heading {{ section.settings.note_heading_size }} awc-note__heading">{{ section.settings.note_heading }}</{{ note_tag }}>
          {% endif %}
          {% if section.settings.note_text != blank %}
            <div class="awc-note__text">{{ section.settings.note_text }}</div>
          {% endif %}
          {% if section.settings.button_text != blank %}
            {% render 'button' %}
          {% endif %}
        </aside>
      {% endif %}
    </div>

  </div>
</section>

<style>
  /* Vertical/horizontal spacing comes from the theme .section class. */
  .awc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;    
    text-align: left;
  }

  .awc-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .awc-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 24px;
    background: rgb(var(--color-foreground) / 0.07);
    border: 1px solid rgb(var(--color-foreground) / 0.12);
    border-radius: 16px;
    transition: border-color 0.2s ease;
  }

  .awc-item:hover {
    border-color: rgb(var(--awc-accent-rgb) / 0.3);
  }

  .awc-item__icon {
    flex-shrink: 0;
    line-height: 0;
    margin-top: 1px;
  }

  .awc-item__icon img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .awc-item__title {
    margin-bottom: 3px;
    color: rgb(var(--color-foreground));
  }

  .awc-item__text {
    font-size: var(--size-text-sm);
    line-height: 1.6;
    color: rgb(var(--color-foreground) / 0.65);
  }

  .awc-note {
    background: rgb(var(--awc-accent-rgb) / 0.08);
    border: 1px solid rgb(var(--awc-accent-rgb) / 0.2);
    border-radius: 16px;
    padding: 32px;
  }

  .awc-note__heading {
    margin-bottom: 14px;
    color: rgb(var(--color-foreground));
  }

  .awc-note__text {
    font-size: var(--size-text-base);
    line-height: 1.75;
    color: rgb(var(--color-foreground) / 0.65);
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .awc-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 600px) {
    .awc-note {
      padding: 24px 20px;
    }
    .awc-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
</style>

