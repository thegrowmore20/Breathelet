{% render 'affiliate-base' %}
<div class="aff-root"><div class="wrap">
  <div class="section-head center reveal"><span class="eyebrow">{{ section.settings.eyebrow }}</span><h2>{{ section.settings.heading }}</h2></div>
  <div class="who-grid">{% for block in section.blocks %}<div class="who-card reveal{% if block.settings.dark %} dark{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.icon }}<h3>{{ block.settings.heading }}</h3><div>{{ block.settings.text }}</div></div>{% endfor %}</div>
</div></div>
{% schema %}
{
  "name": "Affiliate · Who can join",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Who can join"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "If your audience trusts you, we'd love to work with you."
    }
  ],
  "blocks": [
    {
      "type": "who_card",
      "name": "Who card",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icon (SVG)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "checkbox",
          "id": "dark",
          "label": "Dark variant",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Affiliate · Who can join",
      "blocks": [
        {
          "type": "who_card",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21c0-4 4-6 8-6s8 2 8 6\"/></svg>",
            "heading": "Influencers & creators",
            "text": "<p>Sharing wellness, lifestyle, and everyday moments.</p>",
            "dark": false
          }
        },
        {
          "type": "who_card",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><path d=\"M4 4h16v16H4z\"/><path d=\"M8 9h8M8 13h6\"/></svg>",
            "heading": "Bloggers & website owners",
            "text": "<p>In mindfulness, productivity, or healthy living.</p>",
            "dark": false
          }
        },
        {
          "type": "who_card",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><path d=\"M12 3v18M5 8l7-5 7 5\"/><circle cx=\"12\" cy=\"14\" r=\"3\"/></svg>",
            "heading": "Wellness professionals",
            "text": "<p>Guiding communities toward calmer routines.</p>",
            "dark": false
          }
        },
        {
          "type": "who_card",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><path d=\"M3 6h18v12H3z\"/><path d=\"M3 7l9 6 9-6\"/></svg>",
            "heading": "Newsletter & email creators",
            "text": "<p>With an audience that trusts their recommendations.</p>",
            "dark": false
          }
        },
        {
          "type": "who_card",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.4\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M3 12h18M12 3c3 3 3 15 0 18M12 3c-3 3-3 15 0 18\"/></svg>",
            "heading": "Social media pages",
            "text": "<p>Built around mindfulness, minimalism, and intention.</p>",
            "dark": false
          }
        },
        {
          "type": "who_card",
          "settings": {
            "icon": "<svg class=\"ico\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#D9A48F\" stroke-width=\"1.4\"><path d=\"M12 3l2.5 6 6.5.5-5 4.2 1.7 6.3L12 16.8 6.3 20 8 13.7 3 9.5 9.5 9z\"/></svg>",
            "heading": "New or established",
            "text": "<p>What matters most is a genuine connection with your audience.</p>",
            "dark": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
