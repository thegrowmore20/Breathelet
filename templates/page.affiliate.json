    "faq": {
      "type": "affiliate-faq",
      "blocks": {
        "faq-1": {
          "type": "faq_item",
          "settings": {
            "question": "Who can join?",
            "answer": "<p>Anyone with an active online presence — influencers, content creators, bloggers, wellness professionals, newsletter owners, website owners, and engaged social media pages.</p>"
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "Is approval required?",
            "answer": "<p>Yes. Every application is reviewed before approval to keep the program high-quality and brand-safe.</p>"
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "How are sales tracked?",
            "answer": "<p>Through Shopify Collabs, using your unique referral link and discount code. Any sale made through your link or code is automatically recorded for commission.</p>"
          }
        },
        "faq-4": {
          "type": "faq_item",
          "settings": {
            "question": "When are commissions paid?",
            "answer": "<p>Commissions are paid monthly for valid, completed sales. There's no minimum payout threshold — you're paid for every valid sale.</p>"
          }
        },
        "faq-5": {
          "type": "faq_item",
          "settings": {
            "question": "What happens if an order is refunded or canceled?",
            "answer": "<p>Commission is only paid on successfully completed sales. If an order is refunded, canceled, or returned, the related commission is canceled or deducted before payout.</p>"
          }
        },
        "faq-6": {
          "type": "faq_item",
          "settings": {
            "question": "Are there promotion restrictions?",
            "answer": "<p>Yes. No spam, misleading or medical claims, fake urgency, false discounts, unauthorized paid ads, or bidding on Breathelet brand keywords.</p>"
          }
        },
        "faq-7": {
          "type": "faq_item",
          "settings": {
            "question": "Can an affiliate account be terminated?",
            "answer": "<p>Yes. Accounts may be terminated for policy violations, fraudulent activity, misleading promotions, damaging the brand's reputation, inactivity, or not following the affiliate agreement.</p>"
          }
        },
        "faq-8": {
          "type": "faq_item",
          "settings": {
            "question": "How do I get help?",
            "answer": "<p>Reach out to Breathelet support through our official email or social channels anytime.</p>"
          }
        }
      },
