{% liquid
  case icon
    when 'at-sign'
      render 'icon-section-at-sign'
    when 'bank-note'
      render 'icon-section-bank-note'
    when 'building'
      render 'icon-section-building'
    when 'check-heart'
      render 'icon-section-check-heart'
    when 'check-verified'
      render 'icon-section-check-verified'
    when 'check'
      render 'icon-section-check'
    when 'credit-card-check'
      render 'icon-section-credit-card-check'
    when 'credit-card-shield'
      render 'icon-section-credit-card-shield'
    when 'credit-card'
      render 'icon-section-credit-card'
    when 'face-smile'
      render 'icon-section-face-smile'
    when 'file'
      render 'icon-section-file'
    when 'gift'
      render 'icon-section-gift'
    when 'headphones'
      render 'icon-section-headphones'
    when 'heart-hand'
      render 'icon-section-heart-hand'
    when 'heart'
      render 'icon-section-heart'
    when 'mail'
      render 'icon-section-mail'
    when 'marker-pin'
      render 'icon-section-marker-pin'
    when 'message-chat-circle'
      render 'icon-section-message-chat-circle'
    when 'message-text-square'
      render 'icon-section-message-text-square'
    when 'package-check'
      render 'icon-section-package-check'
    when 'package'
      render 'icon-section-package'
    when 'percent'
      render 'icon-section-percent'
    when 'phone'
      render 'icon-section-phone'
    when 'plane'
      render 'icon-section-plane'
    when 'return'
      render 'icon-section-return'
    when 'shield'
      render 'icon-section-shield'
    when 'shopping-cart'
      render 'icon-section-shopping-cart'
    when 'star'
      render 'icon-section-star'
    when 'store'
      render 'icon-section-store'
    when 'tag'
      render 'icon-section-tag'
    when 'target'
      render 'icon-section-target'
    when 'thumbs-up'
      render 'icon-section-thumbs-up'
    when 'truck'
      render 'icon-section-truck'
    when 'user'
      render 'icon-section-user'
    when 'voicemail'
      render 'icon-section-voicemail'
  endcase
%}
