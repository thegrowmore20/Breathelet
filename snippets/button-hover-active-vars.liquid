{% liquid
  assign brightness = color | color_brightness
  if brightness < 220
    assign hover = color | color_lighten: 6
    assign active = color | color_darken: 6
  else
    assign hover = color | color_darken: 5
    assign active = color | color_darken: 10
  endif
-%}

{{ var }}-hover: {{ hover.rgb }}; {{ var }}-active: {{ active.rgb }};
