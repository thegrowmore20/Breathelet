<ul
  class="text-xs md:text-sm list-unstyled flex flex-col gap-2"
  role="list"
  aria-label="{{ 'customer.order.discount' | t }}"
>
  {% for discount_allocation in item.line_level_discount_allocations %}
    <li class="flex items-center gap-1 md:gap-1 font-500 color-green">
      <div class="icon-xs md:icon-xs" style="--icon-stroke-width: 1.75">
        {% render 'icon-discount' %}
      </div>
      <span>
        {{ discount_allocation.discount_application.title }}
        {% comment %} (-{{ discount_allocation.discount_application.total_allocated_amount | money }}) {% endcomment %}
      </span>
    </li>
  {% endfor %}
</ul>
