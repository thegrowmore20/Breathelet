<mega-menu-horizontal
  interaction-handler="{{ interaction_handler | default: "click" }}"
  style="--promo-image-width: {{ block.settings.promo_image_width }}px;"
  {{ block.shopify_attributes }}
  data-block-id="{{ block.id }}"
>
  <details>
    <summary>
      <a href="{{ link.url }}" class="menu-item">
        {{ link.title }}

        <div class="collapse-chevron w-3 ml-2">
          {% render 'icon-chevron' %}
        </div>
      </a>
    </summary>
    <div
      class="mega__menu_products mega-menu-horizontal absolute left-0 right-0 top-full overflow-hidden"
    >
      <div
        class="mega-menu-horizontal__inner overflow-y-auto overscroll-y-contain border-t bg-background min-h-[300px]"
      >
        <div class="container flex gap-12 xl:gap-16 pt-8 pb-16 hd:pt-12">

          {% capture image_sizes %}
            {% render 'product-carousel-image-sizes',
                enabled: false,
                grid_columns: false,
                grid_columns_mobile: false
            %}
          {% endcapture %}

          {% capture card_attrs %}
          data-animation="block"
          data-animation-group="{{ section.id }}-product-cards"
          {% endcapture %}

          <div data-variants="{{ mega_menu_products_show_variants }}" class="grow auto-rows-min grid grid-cols-mega-menu-horizontal-items mega-menu-width-adjust {{ block.settings.menu_max_width }} gap-x-3 gap-y-3 styled-links break-anywhere">
            {% if mega_menu_products_show_variants %}
              {% for product in block.settings.products %}
                {% if product.has_only_default_variant %}
                  {% comment %} Single-variant product — no opt-in possible, render product card {% endcomment %}
                  {% render 'mega-menu-product-cards',
                    card_product: product,
                    attrs: card_attrs,
                    class: "h-full",
                    sizes: image_sizes
                  %}
                {% else %}
                  {%- assign has_opted_in = false -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.metafields.custom.show_as_product_card.value -%}
                      {%- assign has_opted_in = true -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}

                  {% if has_opted_in %}
                    {% for variant in product.variants %}
                      {% unless variant.metafields.custom.show_as_product_card.value %}{% continue %}{% endunless %}
                      {% render 'mega-menu-product-cards',
                        card_product: product,
                        card_variant: variant,
                        attrs: card_attrs,
                        class: "h-full",
                        sizes: image_sizes
                      %}
                    {% endfor %}
                  {% else %}
                    {% comment %} Multi-variant but none opted in — fall back to product card {% endcomment %}
                    {% render 'mega-menu-product-cards',
                      card_product: product,
                      attrs: card_attrs,
                      class: "h-full",
                      sizes: image_sizes
                    %}
                  {% endif %}
                {% endif %}
              {% endfor %}
            {% else %}
              {% for product in block.settings.products %}
                {% render 'mega-menu-product-cards', card_product: product, attrs: card_attrs, class: "h-full", sizes: image_sizes %}
              {% endfor %}
            {% endif %}
          </div>

        </div>
      </div>
    </div>
  </details>
</mega-menu-horizontal>
