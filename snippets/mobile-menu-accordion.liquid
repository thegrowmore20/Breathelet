{%- comment -%}
  Accordion-style mobile menu item — replaces mobile-menu-page (sliding panels).
  Parameters:
    link  — Shopify nav link object
    level — current depth (starts at 1)
  `section` is a Shopify global; no need to pass it explicitly.
{%- endcomment -%}

{%- assign child_level = level | plus: 1 -%}

{%- comment -%}
  Resolve the display image for this link.
  Rules (in priority order):
    1. product_link with ?variant=ID in URL → variant.featured_media, else product.featured_image
    2. product_link without variant param   → product.featured_image
    3. http_link pointing to /products/…   → same variant/product logic via all_products
    4. All other link types                → no image
{%- endcomment -%}
{%- liquid
  assign nav_img = nil

  if link.type == 'product_link'
    assign nav_img = link.object.featured_image
    if link.url contains '?variant='
      assign variant_id_str = link.url | split: '?variant=' | last | split: '&' | first
      assign variant_id = variant_id_str | plus: 0
      for v in link.object.variants
        if v.id == variant_id
          if v.featured_media
            assign nav_img = v.featured_media.preview_image
          endif
          break
        endif
      endfor
    endif

  elsif link.type == 'http_link' and link.url contains '/products/'
    assign url_path = link.url | split: '?' | first
    assign product_handle = url_path | split: '/' | last
    assign nav_product = all_products[product_handle]
    if nav_product != blank
      assign nav_img = nav_product.featured_image
      if link.url contains '?variant='
        assign variant_id_str = link.url | split: '?variant=' | last | split: '&' | first
        assign variant_id = variant_id_str | plus: 0
        for v in nav_product.variants
          if v.id == variant_id
            if v.featured_media
              assign nav_img = v.featured_media.preview_image
            endif
            break
          endif
        endfor
      endif
    endif
  endif
-%}

{%- if link.links != blank -%}
  <smooth-collapse
    class="block"
    group="mobile-menu-l{{ level }}"
    animation="simple"
  >
    <details class="mobile-menu-accordion-item">
      <summary class="side-menu-item mobile-menu-accordion-trigger{% if level > 1 %} side-menu-item--sub{% endif %}">
        {%- if nav_img -%}
          <div class="mobile-menu-item-img">
            {{- nav_img | image_url: width: 80 | image_tag: loading: 'lazy', alt: nav_img.alt -}}
          </div>
        {%- endif -%}
        <span>{{ link.title }}</span>
        <div class="collapse-chevron ml-auto">{% render 'icon-chevron' %}</div>
      </summary>

      <div>
        {%- for sub in link.links -%}
          {%- render 'mobile-menu-accordion', link: sub, level: child_level -%}
        {%- endfor -%}

        {%- comment -%} Mega-menu promo images (carried over from mobile-menu-page) {%- endcomment -%}
        {%- liquid
          assign mega_menu_block = false
          for block in section.blocks
            assign block_menu_item = block.settings.menu_item | downcase
            assign link_title = link.title | downcase
            if block.type == 'mega_menu' and block_menu_item == link_title
              assign mega_menu_block = block
            endif
          endfor
        -%}
        {%- if mega_menu_block
          and mega_menu_block.settings.show_promo_images_on_mobile
          and mega_menu_block.settings.image1
          or mega_menu_block.settings.image2
        -%}
          <div class="mobile-menu-promo-images grid-carousel scroll-area-x">
            {%- if mega_menu_block.settings.image1 -%}
              {%- render 'mega-menu-image',
                image: mega_menu_block.settings.image1,
                url: mega_menu_block.settings.image1_url,
                heading: mega_menu_block.settings.image1_heading,
                width: 512
              -%}
            {%- endif -%}
            {%- if mega_menu_block.settings.image2 -%}
              {%- render 'mega-menu-image',
                image: mega_menu_block.settings.image2,
                url: mega_menu_block.settings.image2_url,
                heading: mega_menu_block.settings.image2_heading,
                width: 512
              -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </details>
  </smooth-collapse>
{%- else -%}
  <a
    href="{{ link.url }}"
    class="side-menu-item{% if level > 1 %} side-menu-item--sub{% endif %}"
    data-instant
  >
    {%- if nav_img -%}
      <div class="mobile-menu-item-img">
        {{- nav_img | image_url: width: 80 | image_tag: loading: 'lazy', alt: nav_img.alt -}}
      </div>
    {%- endif -%}
    <span>{{ link.title }}</span>
  </a>
{%- endif -%}
