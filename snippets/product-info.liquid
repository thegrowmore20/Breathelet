{% liquid
  assign current_variant = current_variant | default: product.selected_or_first_available_variant
%}

<sticky-sidebar
  class="
    product-info
    {% if section.settings.show_breadcrumbs %} !pt-0 {% endif %}
  "
  top-offset="48"
  bottom-offset="48"
  disable-below="992"
>
  <div
    class="product-info-inner color trim-margins w-full"
    id="Product-Info-{{ section.id }}"
    style="
      {%- render 'apply-color-var', var: '--color-background', color: section.settings.buy_section_background_color -%}
      {%- render 'apply-color-var', var: '--color-foreground', color: section.settings.buy_section_text_color -%}
      {%- render 'apply-color-var', var: '--color-headings', color: section.settings.buy_section_text_color -%}
    "
  >
    {% assign product_form_id = 'Product-Form-' | append: section.id %}

    {% for block in section.blocks %}
      {% case block.type %}
        {% when '@app' %}
          {% render block %}
        {% when 'vendor' %}
          <div
            class="product-vendor my-1 md:my-2 text-foreground/75 styled-links tracking-wider max-md:text-sm"
            {{ block.shopify_attributes }}
          >
            {% if product == null %}
              Vendor
            {% else %}
              {{ product.vendor | link_to_vendor }}
            {% endif %}
          </div>
        {% when 'title' %}
          <div
            class="product-name-wrapper my-1 md:my-2"
            {{ block.shopify_attributes }}
            style="{%- render 'apply-color-var', var: '--color-headings', color: block.settings.text_color -%}"
          >
            {% if request.page_type != 'product' %}
              <a data-instant href="{{ product.url }}">
                <h2 class="{{ block.settings.heading_size }} mb-2">
                  {{ product.title | default: 'Product' }}
                </h2>
              </a>

              <a
                data-instant
                href="{{ product.url }}"
                class="styled-link inline-block text-foreground/75 max-md:text-sm"
              >
                {{ 'products.product.view_full_details' | t }}
              </a>
            {% else %}
              <h1 class="{{ block.settings.heading_size }}">
                {{ block.settings.content | default: product.title }}
              </h1>
            {% endif %}
          </div>
        {% when 'rating' %}
          {% if block.settings.show_empty_rating or product.metafields.reviews.rating.value != blank %}
            <div
              id="rating-{{ block.id }}"
              class="my-3 md:my-4"
              {{ block.shopify_attributes }}
            >
              <style>
                #rating-{{ block.id }} {
                  --rating-font-size: {{ block.settings.star_size | times: 0.75 | divided_by: 4.0 | round | times: 4 | divided_by: 16.0 | at_least: 1 }};
                }

                @media (min-width: 768px) {
                  #rating-{{ block.id }} {
                    --rating-font-size: {{ block.settings.star_size | divided_by: 16.0 }};
                  }
                }
              </style>
              <a
                href="{% if request.page_type != 'product' %}{{ product.url }}{% endif %}#shopify-product-reviews"
                class="product-rating"
              >
                {% render 'product-rating', product: product, show_rating_value: true %}
              </a>
            </div>
          {% endif %}
        {% when 'sku' %}
          <div class="product-sku-list my-2 empty:hidden" data-variant-info="sku">
            {%- render 'product-sku', product: product -%}
          </div>
        {% when 'product_highlights' %}
          {% if block.settings.content != blank %}
            <div
              class="my-6 product-highlights-list product-highlights-list--{{ block.settings.icon_type }}"
              style="
                {%- render 'apply-color-var', var: '--product-highlights-icon-color', color: block.settings.icon_color, opacity: 1.0 -%}
                {%- render 'apply-color-var', var: '--color-foreground', color: block.settings.text_color -%}
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.content }}
            </div>
          {% endif %}

        {% when 'price' %}
          <div
            class="product-price {% if block.settings.use_bold_font %} bold {% endif %}"
            data-variant-info="price"
            {{ block.shopify_attributes }}
          >
            {% render 'product-page-price', product: product, block: block %}
          </div>
        {% when 'delivery' %}
          {% if product.selected_or_first_available_variant.available %}
            {% render 'product-delivery-dates', block: block, class: 'my-4', text_size_delivery_class: 'text-sm md:text-base' %}           
          {% endif %}
        
        {% when 'icon_text_block' %}
          <style>
            .icon-text-block {
              width: 100%;
            }

            /* INLINE (all items in one row, icon top, text below) */
            .icon-text-block--inline {
              display: flex;
              flex-wrap: wrap;
              gap: 20px;
            }

            .icon-text-block--inline .icon-text-item {
              flex: 1 1 0;
              display: flex;
              flex-direction: column;
              align-items: center;
              text-align: center;
              gap: 1rem;
            }

            /* VERTICAL (each item row, icon left, text right) */
            .icon-text-block--vertical {
              display: flex;
              flex-direction: column;
              gap: 15px;
            }

            .icon-text-block--vertical .icon-text-item {
              display: flex;
              align-items: center;
              gap: 12px;
            }

            .icon-wrapper img {
              display: block;
              height: auto;
            }

            .icon-wrapper{
              {% comment %} background-color: #f9f9f9; {% endcomment %}
              padding: 10px;
              border-radius: 50%;
            }

            .icon-text {
              line-height: 1.4;
            }

            .icon-text-block--vertical.homepage-usps-info .icon-text-item {
                  width: calc(50% - 12px);
              }

              .icon-text-block--vertical.homepage-usps-info {
                  flex-direction: row;
                  flex-wrap: wrap;
              }

            @media (max-width: 520px) {
              .icon-text-block--inline {
                display: grid;
                grid-template-columns: 1fr 1fr;
              }    
              
              .icon-text-block--vertical.homepage-usps-info .icon-text-item {
                  align-items: flex-start;
              }
            }
          </style>
          {% assign country_handle = localization.country | handle %}
          <div class="icon-text-block my-4 icon-text-block--{{ block.settings.layout }} {{ block.settings.icon_text_class }} {{ country_handle }} {% unless country_handle == 'united-states' %} not-usa {% endunless %}" {{ block.shopify_attributes }}>

            {% for i in (1..5) %}
              {% comment %} Logic to skip items based on country {% endcomment %}
              {% if country_handle == 'united-states' and i == 4 %}
                {% continue %}
              {% elsif country_handle != 'united-states' and i == 3 %}
                {% continue %}
              {% endif %}

              {% capture icon_key %}icon_{{ i }}{% endcapture %}
              {% capture text_key %}text_{{ i }}{% endcapture %}
              {% assign icon = block.settings[icon_key] %}
              {% assign text = block.settings[text_key] %}

              {%- liquid
                assign lazyload = 'lazy'
                if forloop.index == 1
                  assign lazyload = 'eager'
                endif
              -%}

              {% if icon != blank or text != blank %}
                <div data-icon="icon_{{ i }}" class="icon-text-item">
                  {% if icon %}
                    <div class="icon-wrapper">
                      <img 
                        src="{{ icon | image_url: width: 100 }}"
                        alt="{{ icon.alt | escape }}" 
                        width="100" height=""
                        style="width: {{ block.settings.icon_size }}px;"
                        loading="{{ lazyload }}"
                      >
                    </div>
                  {% endif %}

                  {% if text != blank %}
                    <div class="icon-text" style="font-size: {{ block.settings.text_size }}px; color: {{ block.settings.text_color }};">
                      {{ text | replace: '<p>', '' | replace: '</p>', '' }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>  
          
        {% when 'payment_installments' %}
          <div {{ block.shopify_attributes }}>
            {%- assign installment_id = 'Installment-' | append: section.id -%}
            {%- form 'product', product, id: installment_id -%}
              <input
                data-variant-info="installment_variant_id"
                type="hidden"
                name="id"
                value="{{ product.selected_or_first_available_variant.id }}"
              >
              {{ form | payment_terms }}
            {%- endform -%}
          </div>
        {% when 'variant_picker' %}
          {% unless product.has_only_default_variant %}
            <div class="product-variant-picker my-6" {{ block.shopify_attributes }}>
              {% render 'product-variant-picker', product: product, product_form_id: product_form_id, block: block %}
            </div>
          {% endunless %}

        {% when 'inventory' %}
          <div
            class="product-stock-info my-6 empty:hidden"
            id="StockInfo-{{ section.id }}"
            data-variant-info="stock"
            {{ block.shopify_attributes }}
          >
            {% render 'product-stock-info', product: product, block: block %}
          </div>

        {% when 'qty_btn_selector' %}

        {% render 'addons_and_free_gifts', product: product %}
          
        <div class="wrapper-with-custom-checkout flex gap-2 flex-col">
          <div class="qty-button-wrapper flex justify-start items-center gap-2 sm:gap-6" {{ block.shopify_attributes }}>
            {% unless block.settings.show_dynamic_checkout_buttons %}
              <div class="qty-wrap">
                <div class="qty-selector-wrapper">
                  {% capture qty_selector_id %}{{ section.id }}-qty-input{% endcapture %}
    
                  <label class="label label-product-info mb-3 hidden" for="{{ qty_selector_id }}">
                    {{ 'products.product.quantity.label' | t }}
                  </label>
    
                  <div>
                    {% render 'qty-selector', product: product, product_form_id: product_form_id, id: qty_selector_id %}
                  </div>
                </div>
              </div>
            {% endunless %}
            <div class="buy-btn-wrap {% unless block.settings.show_dynamic_checkout_buttons %}grow{% endunless %}">
              <div class="product-buy-buttons">
               {% render 'product-page-buy-buttons', product: product, product_form_id: product_form_id, block: block %}
             </div>
            </div>            
          </div>          

          {% unless block.settings.show_dynamic_checkout_buttons %}
            {% render 'custom-checkout-button', product: product %}
          {% endunless %}
      

          </div>  

        {% when 'quantity_selector' %}
          <div class="qty-selector-wrapper my-6" {{ block.shopify_attributes }}>
            {% capture qty_selector_id %}{{ section.id }}-qty-input{% endcapture %}

            <label class="label label-product-info mb-3" for="{{ qty_selector_id }}">
              {{ 'products.product.quantity.label' | t }}
            </label>

            <div>
              {% render 'qty-selector', product: product, product_form_id: product_form_id, id: qty_selector_id %}
            </div>
          </div>
        {% when 'buy_buttons' %}
          <div class="product-buy-buttons my-8" {{ block.shopify_attributes }}>
            {% render 'product-page-buy-buttons', product: product, product_form_id: product_form_id, block: block %}
          </div>
        {% when 'pickup_availability' %}
          {% render 'product-pickup-availability',
            product_variant: product.selected_or_first_available_variant,
            class: 'my-6',
            block: block
          %}
        {% when 'complementary_products' %}
          {% render 'product-complementary-products', product: product, class: 'my-8 md:my-12', block: block %}
        {% when 'share_button' %}
          <div class="share-button-wrapper my-6" {{ block.shopify_attributes }}>
            {% render 'share-button' %}
          </div>
        {% when 'separator' %}
          <hr class="my-6" {{ block.shopify_attributes }}>
        {% when 'hook_text' -%}
          {%- liquid
            # Short description: variant metafield wins; fall back to the product
            # metafield when the product has no variants or the variant value is empty.
            assign variant_sd = product.selected_or_first_available_variant.metafields.custom.short_description | metafield_tag
            assign product_sd = product.metafields.custom.short_description | metafield_tag
            if variant_sd != blank
              assign hook_short_description = variant_sd
            elsif product_sd != blank
              assign hook_short_description = product_sd
            else
              assign hook_short_description = blank
            endif
          -%}
          <div
            class="my-4 md:my-6 prose max-w-none hooktext"
            id="hooktext"
            data-variant-info="hook-text-{{ block.id }}"
          >
            {%- if hook_short_description != blank -%}
              {{ hook_short_description }}
            {%- else -%}
              {{ block.settings.content }}
            {%- endif -%}
          </div>
        {% when 'text' -%}
          <div class="my-4 md:my-6 prose max-w-none">
            {{ block.settings.content }}
          </div>
        {% when 'rich_text_block' %}
          {% render 'product-rich-text', block: block %}
        {% when 'description' %}
          {% render 'product-description', block: block, product: product, class: 'my-6 md:my-8' %}
        {% when 'collapsible_content' %}
          {% render 'product-collapsible-variant-based', block: block %}
        {% when 'custom_liquid' %}
          {% render 'product-custom-liquid', block: block %}
        {% when 'image' %}
          {% render 'product-image', block: block %}
        {% when 'custom_badges' %}
          <div class="product-custom-badges" {{ block.shopify_attributes }}>
            {%- render 'product-custom-badges', product: product -%}
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  {% render 'product-quick-add-media' %}

  <template class="product-quick-add-header-template">
    {% render 'product-quick-add-header', product: product %}
  </template>

  <script type="application/json" data-variant-info="json">
    {{ product.selected_or_first_available_variant | json }}
  </script>
</sticky-sidebar>


<script>
  document.addEventListener('DOMContentLoaded', function () {
    const accordions = document.querySelectorAll('.product-collapse');

    accordions.forEach((accordion) => {
      accordion.addEventListener('toggle', function () {
        // Run only when opening
        if (!accordion.open) return;

        // Delay to allow other accordion to collapse + DOM height settle
        setTimeout(() => {
          const summary = accordion.querySelector('summary');
          if (!summary) return;

          const rect = summary.getBoundingClientRect();

          // Only scroll if header is out of view (prevents unnecessary jump)
          if (rect.top < 0 || rect.top > window.innerHeight) {

            // Adjust this if you have sticky header
            const OFFSET = -100;

            const targetY = rect.top + window.pageYOffset + OFFSET;

            window.scrollTo({
              top: targetY,
              behavior: 'smooth'
            });
          }

        }, 150); // adjust (150–300ms) based on collapse animation speed
      });
    });
  });
</script>