{%- liquid
  assign parts = block.settings.variant_metafield | split: '.'
  assign ns = parts | first
  assign key = parts | last

  assign selected = product.selected_or_first_available_variant
  assign sel_vc = selected.metafields[ns][key] | metafield_tag
  if sel_vc != blank
    assign initial_content = sel_vc
  else
    assign initial_content = block.settings.content
  endif

  assign has_variant_content = false
  for variant in product.variants
    if variant.metafields[ns][key] != blank
      assign has_variant_content = true
      break
    endif
  endfor
-%}

{% if block.settings.content != blank or has_variant_content %}
  <smooth-collapse
    {{ block.shopify_attributes }}
    class="product-collapse-wrapper block"
    {% if block.settings.collapse_open %}default-open{% endif %}
  >
    <details class="product-collapse" {% if block.settings.collapse_open %}open{% endif %}>
      <summary>
        <div class="font-accordion product-info-heading">{{ block.settings.heading }}</div>
        {% render 'icon-chevron' %}
      </summary>

      <div class="prose max-w-none" data-collapsible-target="{{ block.id }}">
        {{ initial_content }}
      </div>
    </details>

    {%- comment -%} Storage: fallback resolved server-side {%- endcomment -%}
    <div data-collapsible-data="{{ block.id }}" hidden>
      <template data-default>{{ block.settings.content }}</template>
      {%- for variant in product.variants -%}
        {%- assign vc = variant.metafields[ns][key] | metafield_tag -%}
        {%- if vc != blank -%}
          <template data-variant-id="{{ variant.id }}">{{ vc }}</template>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </smooth-collapse>
{% endif %}