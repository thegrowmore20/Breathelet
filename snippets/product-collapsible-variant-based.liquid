{%- liquid
  assign parts = block.settings.variant_metafield | split: '.'
  assign ns = parts | first
  assign key = parts | last

  assign selected = product.selected_or_first_available_variant
  assign variant_value = selected.metafields[ns][key] | metafield_tag
  assign product_value = product.metafields[ns][key] | metafield_tag

  # Resolution order: variant metafield → product metafield → static content.
  # The product value covers products with no variants or with an empty
  # variant value, mirroring the short-description behaviour.
  if variant_value != blank
    assign initial_content = variant_value
  elsif product_value != blank
    assign initial_content = product_value
  else
    assign initial_content = block.settings.content
  endif
-%}

{% if initial_content != blank %}
  <smooth-collapse
    {{ block.shopify_attributes }}
    class="product-collapse-wrapper block"
    {% if block.settings.collapse_open %}default-open{% endif %}
  >
    <details class="product-collapse" {% if block.settings.collapse_open %}open{% endif %}>
      <summary>
        <div class="font-accordion product-info-heading">{{ block.settings.heading }}</div>
        {% render 'icon-chevron' %}
      </summary>

      <div class="prose max-w-none" data-variant-info="collapsible-{{ block.id }}">
        {{ initial_content }}
      </div>
    </details>
  </smooth-collapse>
{% endif %}