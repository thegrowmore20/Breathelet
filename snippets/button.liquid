{% liquid
  assign target = target | default: section

  unless defaults == false
    assign link = link | default: target.settings.button_link
    assign style = style | default: target.settings.button_style
    assign size = size | default: target.settings.button_size
    assign text = text | default: target.settings.button_text
    assign background_color = background_color | default: target.settings.button_background_color
    assign text_color = text_color | default: target.settings.button_text_color

    assign hover_style = hover_style | default: target.settings.button_hover_style
    assign hover_size = hover_size | default: target.settings.button_hover_size
    assign hover_background_color = hover_background_color | default: target.settings.button_hover_background_color
    assign hover_text_color = hover_text_color | default: target.settings.button_hover_text_color
  endunless

  assign tag = 'button'

  if link != blank and section.settings.link == blank
    assign tag = 'a'
  endif

  assign has_hover_background = false
  if hover_background_color != blank and hover_background_color.rgba != '0 0 0 / 0.0'
    assign has_hover_background = true
  endif

  assign has_hover_text = false
  if hover_text_color != blank and hover_text_color.rgba != '0 0 0 / 0.0'
    assign has_hover_text = true
  endif

  assign has_hover = false
  if hover_style != blank or hover_size != blank or has_hover_background or has_hover_text
    assign has_hover = true
  endif

  assign button_uid = 'button-' | append: target.id

  case hover_size
    when 'xs'
      assign hover_font_size = 'var(--size-text-xs)'
      assign hover_font_size_md = 'var(--size-text-sm)'
    when 'sm'
      assign hover_font_size = 'var(--size-text-sm)'
      assign hover_font_size_md = 'var(--size-text-base)'
    when 'base'
      assign hover_font_size = 'var(--size-text-base)'
      assign hover_font_size_md = 'var(--size-text-lg)'
    when 'lg'
      assign hover_font_size = 'var(--size-text-lg)'
      assign hover_font_size_md = 'var(--size-text-h5)'
  endcase
%}

<{{ tag }}
  {% if link != blank %}
    href="{{ link }}"
    data-instant
  {% endif %}
  {% if has_hover %}id="{{ button_uid }}"{% endif %}
  class="button {{ style }} {{ size }}"
  style="{% render 'button-vars', background: background_color, text: text_color %}"
  {{ attrs }}
>
  {{ text }}
</{{ tag }}>

{% if has_hover %}
  {% style %}
    {% if has_hover_background %}
      #{{ button_uid }}:hover { background: {{ hover_background_color }} !important; }
    {% endif %}
    {% if has_hover_text %}
      #{{ button_uid }}:hover { color: {{ hover_text_color }} !important; }
    {% endif %}
    {% if hover_style == 'outline' %}
      #{{ button_uid }}:hover {
        background: transparent !important;
        color: {% if has_hover_text %}{{ hover_text_color }}{% elsif has_hover_background %}{{ hover_background_color }}{% else %}rgb(var(--button-background)){% endif %} !important;
        box-shadow: inset 0 0 0 2px {% if has_hover_background %}{{ hover_background_color }}{% else %}rgb(var(--button-background)){% endif %} !important;
      }
    {% elsif hover_style == 'filled' %}
      #{{ button_uid }}:hover {
        background: {% if has_hover_background %}{{ hover_background_color }}{% else %}rgb(var(--button-background-hover) / var(--button-background-hover-opacity, 1)){% endif %} !important;
        color: {% if has_hover_text %}{{ hover_text_color }}{% else %}rgb(var(--button-foreground)){% endif %} !important;
        box-shadow: none !important;
      }
    {% endif %}
    {% if hover_size != blank %}
      #{{ button_uid }}:hover { font-size: {{ hover_font_size }} !important; }
      @media (min-width: 768px) {
        #{{ button_uid }}:hover { font-size: {{ hover_font_size_md }} !important; }
      }
    {% endif %}
  {% endstyle %}
{% endif %}
