{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign metafield_namespace = block.settings.metafield_namespace | strip
  assign metafield_key = block.settings.metafield_key | strip
  assign video_entries = product.metafields[metafield_namespace][metafield_key].value

  if video_entries == blank
    assign video_entries = product.metafields.custom.youtube_shorts.value
  endif

  if video_entries == blank
    assign video_entries = shop.metaobjects.youtube_shorts.values
  endif
%}


{% if video_entries != blank %}
  {%- comment -%}
    PERF: Only preconnect to the thumbnail CDN (loaded on view).
    The video player domain is contacted on click, so no need to preconnect it upfront.
  {%- endcomment -%}
  <link rel="preconnect" href="https://i.ytimg.com" crossorigin>

  {% style %}
    .ai-video-slider-{{ ai_gen_id }} {
      display: block;
      width: {{ block.settings.desktop_width_percent }}%;
      max-width: 100%;
      margin: 0 auto;
      padding: {{ block.settings.section_padding }}px 0;
    }

    .ai-video-slider-wrapper-{{ ai_gen_id }} {
      position: relative;
      overflow: hidden;
      width: 100%;
      padding: 0;
      cursor: grab;
    }

    .ai-video-slider-wrapper-{{ ai_gen_id }}.dragging {
      cursor: grabbing;
    }

    .ai-video-slider-track-{{ ai_gen_id }} {
      display: flex;
      gap: {{ block.settings.slide_gap }}px;
      transition: transform 0.3s ease;
      user-select: none;
    }

    .ai-video-slider-track-{{ ai_gen_id }}.dragging {
      transition: none;
    }

    /* Slide is now a lightweight facade BUTTON (thumbnail + play icon), not an iframe */
    .ai-video-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_desktop | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_desktop }});
      position: relative;
      aspect-ratio: 9 / 16;
      border-radius: {{ block.settings.video_border_radius }}px;
      overflow: hidden;
      background-color: #000;
      padding: 0;
      margin: 0;
      border: none;
      display: block;
      cursor: pointer;
      -webkit-appearance: none;
      appearance: none;
    }

    .ai-video-slide-{{ ai_gen_id }}:focus-visible {
      outline: 2px solid #ffffff;
      outline-offset: 2px;
    }

    .ai-video-thumb-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none;
    }

    /* Native YouTube play button (same look as the real embed) */
    .ai-video-play-{{ ai_gen_id }} {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 68px;
      height: 48px;
      pointer-events: none;
      transition: transform 0.15s ease;
    }

    .ai-video-slide-{{ ai_gen_id }}:hover .ai-video-play-{{ ai_gen_id }} {
      transform: translate(-50%, -50%) scale(1.05);
    }

    .ai-video-play-{{ ai_gen_id }} svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Injected iframe (after click) fills the slide */
    .ai-video-slide-{{ ai_gen_id }} iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }

    .ai-video-slider-controls-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: {{ block.settings.controls_spacing }}px;
    }

    .ai-video-slider-arrow-{{ ai_gen_id }} {
      background-color: {{ block.settings.arrow_background }};
      color: {{ block.settings.arrow_color }};
      border: 1px solid #E6E6E6;
      width: {{ block.settings.arrow_size }}px;
      height: {{ block.settings.arrow_size }}px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      flex-shrink: 0;
    }

    .ai-video-slider-arrow-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.arrow_hover_background }};
      color: {{ block.settings.arrow_hover_color }};
      transform: scale(1.1);
    }

    .ai-video-slider-arrow-{{ ai_gen_id }}:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .ai-video-slider-arrow-{{ ai_gen_id }}:disabled:hover {
      transform: none;
    }

    .ai-video-slider-dots-{{ ai_gen_id }} {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .ai-video-slider-dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size }}px;
      height: {{ block.settings.dot_size }}px;
      border-radius: 50%;
      background-color: {{ block.settings.dot_color }};
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      padding: 0;
    }

    .ai-video-slider-dot-{{ ai_gen_id }}.active {
      background-color: {{ block.settings.dot_active_color }};
    }

    .ai-video-slider-dot-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.dot_active_color }};
    }

    @media screen and (max-width: 991px) and (min-width: 768px) {
      .ai-video-slide-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - ({{ block.settings.slides_medium | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_medium }});
      }
    }

    @media screen and (max-width: 767px) {
      .ai-video-slide-{{ ai_gen_id }} {
        flex: 0 0 calc((100% - ({{ block.settings.slides_mobile | minus: 1 }} * {{ block.settings.slide_gap }}px)) / {{ block.settings.slides_mobile }});
      }
    }
  {% endstyle %}

  <video-slider-{{ ai_gen_id }} class="ai-video-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="ai-video-slider-wrapper-{{ ai_gen_id }}" data-wrapper>
      <div class="ai-video-slider-track-{{ ai_gen_id }}" data-track>
        {% for entry in video_entries limit: block.settings.max_items %}
          {% liquid
            assign video_url = entry.link.value
            assign video_id = ''
            assign video_type = ''

            if video_url contains 'youtube.com' or video_url contains 'youtu.be'
              assign video_type = 'youtube'
              if video_url contains 'youtu.be/'
                assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
              elsif video_url contains 'shorts/'
                assign video_id = video_url | split: 'shorts/' | last | split: '?' | first
              elsif video_url contains 'watch?v='
                assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first
              elsif video_url contains 'embed/'
                assign video_id = video_url | split: 'embed/' | last | split: '?' | first
              endif
            elsif video_url contains 'vimeo.com'
              assign video_type = 'vimeo'
              assign video_id = video_url | split: 'vimeo.com/' | last | split: '/' | first
            endif
          %}

          {% if video_id != blank %}
            <button
              type="button"
              class="ai-video-slide-{{ ai_gen_id }}"
              data-slide
              data-video-type="{{ video_type }}"
              data-video-id="{{ video_id }}"
              aria-label="Play video {{ forloop.index }}"
            >
              {% if video_type == 'youtube' %}
                {%- comment -%} hqdefault always exists for every video/short. Swap to maxresdefault if you want crisper thumbs (add an onerror fallback if you do). {%- endcomment -%}
                <img
                  class="ai-video-thumb-{{ ai_gen_id }}"
                  src="https://i.ytimg.com/vi/{{ video_id }}/hqdefault.jpg"
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="480"
                  height="360"
                >
              {% endif %}
              <span class="ai-video-play-{{ ai_gen_id }}" aria-hidden="true">
                <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                  <path d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="#f00"></path>
                  <path d="M 45,24 27,14 27,34" fill="#fff"></path>
                </svg>
              </span>
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-video-slider-controls-{{ ai_gen_id }}" data-controls>
      {% if block.settings.show_arrows %}
        <button class="ai-video-slider-arrow-{{ ai_gen_id }}" data-prev aria-label="Previous slide">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_dots %}
        <div class="ai-video-slider-dots-{{ ai_gen_id }}" data-dots></div>
      {% endif %}

      {% if block.settings.show_arrows %}
        <button class="ai-video-slider-arrow-{{ ai_gen_id }}" data-next aria-label="Next slide">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>
  </video-slider-{{ ai_gen_id }}>

  <script>
    (function() {
      class VideoSlider{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
          this.currentIndex = 0;
          this.isDragging = false;
          this.startPos = 0;
          this.currentTranslate = 0;
          this.prevTranslate = 0;
          this.dragStartTime = 0;
          this.hasDragged = false;
          this.autoChange = {{ block.settings.auto_change | json }};
          this.autoChangeInterval = {{ block.settings.auto_change_interval | default: 4 }} * 1000;
          this.autoplayTimer = null;
        }

        connectedCallback() {
          this.wrapper = this.querySelector('[data-wrapper]');
          this.track = this.querySelector('[data-track]');
          this.slides = this.querySelectorAll('[data-slide]');
          this.prevBtn = this.querySelector('[data-prev]');
          this.nextBtn = this.querySelector('[data-next]');
          this.dotsContainer = this.querySelector('[data-dots]');
          this.controlsContainer = this.querySelector('[data-controls]');

          this.slidesPerView = this.getSlidesPerView();
          this.totalSlides = this.slides.length;
          this.setSlideWidths();
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

          // Facades are always clickable, even when the slider itself isn't needed.
          this.setupFacadeClicks();

          if (this.totalSlides <= this.slidesPerView) {
            if (this.controlsContainer) {
              this.controlsContainer.style.display = 'none';
            }
            return;
          }

          this.setupEventListeners();
          this.createDots();
          this.updateControls();
          this.startAutoplay();

          window.addEventListener('resize', () => {
            this.handleResize();
          });
        }

        /* Click a thumbnail -> build + inject the real iframe (this is when YouTube JS finally loads). */
        setupFacadeClicks() {
          this.slides.forEach(slide => {
            slide.addEventListener('click', () => {
              if (this.hasDragged) return;
              this.playSlide(slide);
            });
          });
        }

        playSlide(slide) {
          if (slide.dataset.loaded === 'true') return;
          const type = slide.dataset.videoType;
          const id = slide.dataset.videoId;
          if (!id) return;

          const mute = {{ block.settings.muted | json }} ? 1 : 0;
          let src = '';

          if (type === 'youtube') {
            src = 'https://www.youtube-nocookie.com/embed/' + id +
              '?autoplay=1&mute=' + mute +
              '&loop=1&playlist=' + id +
              '&controls=1&modestbranding=1&rel=0&playsinline=1';
          } else if (type === 'vimeo') {
            src = 'https://player.vimeo.com/video/' + id +
              '?autoplay=1&muted=' + mute +
              '&loop=1&controls=1&playsinline=1';
          }
          if (!src) return;

          const iframe = document.createElement('iframe');
          iframe.src = src;
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen');
          iframe.setAttribute('allowfullscreen', '');
          iframe.setAttribute('title', 'Video');
          slide.innerHTML = '';
          slide.appendChild(iframe);
          slide.dataset.loaded = 'true';
        }

        startAutoplay() {
          if (!this.autoChange) return;
          if (this.totalSlides <= this.slidesPerView) return;
          this.stopAutoplay();
          this.autoplayTimer = setInterval(() => {
            if (this.currentIndex >= this.maxIndex) {
              this.currentIndex = 0;
            } else {
              this.currentIndex++;
            }
            this.updateSlider();
          }, this.autoChangeInterval);
        }

        stopAutoplay() {
          if (this.autoplayTimer) {
            clearInterval(this.autoplayTimer);
            this.autoplayTimer = null;
          }
        }

        setSlideWidths() {
          const wrapperWidth = this.wrapper.offsetWidth;
          if (!wrapperWidth) return;
          const gap = {{ block.settings.slide_gap }};
          const perView = this.slidesPerView;
          const slideWidth = (wrapperWidth - gap * (perView - 1)) / perView;
          this.slides.forEach(slide => {
            slide.style.flex = `0 0 ${slideWidth}px`;
          });
        }

        getSlidesPerView() {
          const width = window.innerWidth;
          if (width < 768) {
            return {{ block.settings.slides_mobile }};
          } else if (width < 992) {
            return {{ block.settings.slides_medium }};
          } else {
            return {{ block.settings.slides_desktop }};
          }
        }

        handleResize() {
          const newSlidesPerView = this.getSlidesPerView();
          this.slidesPerView = newSlidesPerView;
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
          this.setSlideWidths();

          if (this.currentIndex > this.maxIndex) {
            this.currentIndex = this.maxIndex;
          }

          if (this.totalSlides <= this.slidesPerView) {
            if (this.controlsContainer) {
              this.controlsContainer.style.display = 'none';
            }
          } else {
            if (this.controlsContainer) {
              this.controlsContainer.style.display = 'flex';
            }
          }

          this.createDots();
          this.updateSlider();
        }

        setupEventListeners() {
          if (this.prevBtn) {
            this.prevBtn.addEventListener('click', () => this.prev());
          }
          if (this.nextBtn) {
            this.nextBtn.addEventListener('click', () => this.next());
          }

          this.wrapper.addEventListener('mousedown', this.dragStart.bind(this));
          this.wrapper.addEventListener('touchstart', this.dragStart.bind(this), { passive: true });

          window.addEventListener('mouseup', this.dragEnd.bind(this));
          window.addEventListener('touchend', this.dragEnd.bind(this));

          window.addEventListener('mousemove', this.drag.bind(this));
          window.addEventListener('touchmove', this.drag.bind(this), { passive: false });

          // Block the click-to-play if the user was actually dragging the slider.
          this.wrapper.addEventListener('click', (e) => {
            if (this.hasDragged) {
              e.preventDefault();
              e.stopPropagation();
            }
          }, true);

          this.wrapper.addEventListener('mouseenter', () => this.stopAutoplay());
          this.wrapper.addEventListener('mouseleave', () => this.startAutoplay());
        }

        createDots() {
          if (!this.dotsContainer) return;

          this.dotsContainer.innerHTML = '';
          const dotsCount = this.maxIndex + 1;

          for (let i = 0; i < dotsCount; i++) {
            const dot = document.createElement('button');
            dot.classList.add('ai-video-slider-dot-{{ ai_gen_id }}');
            dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
            if (i === this.currentIndex) {
              dot.classList.add('active');
            }
            dot.addEventListener('click', () => this.goToSlide(i));
            this.dotsContainer.appendChild(dot);
          }
        }

        updateControls() {
          if (this.prevBtn) {
            this.prevBtn.disabled = this.currentIndex === 0;
          }
          if (this.nextBtn) {
            this.nextBtn.disabled = this.currentIndex >= this.maxIndex;
          }

          if (this.dotsContainer) {
            const dots = this.dotsContainer.querySelectorAll('.ai-video-slider-dot-{{ ai_gen_id }}');
            dots.forEach((dot, index) => {
              if (index === this.currentIndex) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }
        }

        updateSlider(animate = true) {
          const slideWidth = this.slides[0].offsetWidth;
          const gap = {{ block.settings.slide_gap }};
          const offset = -(this.currentIndex * (slideWidth + gap));

          if (!animate) {
            this.track.style.transition = 'none';
          }

          this.track.style.transform = `translateX(${offset}px)`;

          if (!animate) {
            this.track.offsetHeight;
            this.track.style.transition = '';
          }

          this.updateControls();
        }

        prev() {
          if (this.currentIndex > 0) {
            this.currentIndex--;
            this.updateSlider();
          }
        }

        next() {
          if (this.currentIndex < this.maxIndex) {
            this.currentIndex++;
            this.updateSlider();
          }
        }

        goToSlide(index) {
          this.currentIndex = index;
          this.updateSlider();
        }

        dragStart(event) {
          this.stopAutoplay();
          this.isDragging = true;
          this.hasDragged = false;
          this.dragStartTime = Date.now();
          this.startPos = this.getPositionX(event);
          this.track.classList.add('dragging');
          this.wrapper.classList.add('dragging');

          const slideWidth = this.slides[0].offsetWidth;
          const gap = {{ block.settings.slide_gap }};
          this.prevTranslate = -(this.currentIndex * (slideWidth + gap));
        }

        drag(event) {
          if (!this.isDragging) return;

          const currentPosition = this.getPositionX(event);
          const diff = currentPosition - this.startPos;

          if (Math.abs(diff) > 5) {
            this.hasDragged = true;
            event.preventDefault();
          }

          this.currentTranslate = this.prevTranslate + diff;
          this.track.style.transform = `translateX(${this.currentTranslate}px)`;
        }

        dragEnd() {
          if (!this.isDragging) return;

          this.isDragging = false;
          this.track.classList.remove('dragging');
          this.wrapper.classList.remove('dragging');

          const movedBy = this.currentTranslate - this.prevTranslate;
          const dragDuration = Date.now() - this.dragStartTime;
          const velocity = Math.abs(movedBy) / dragDuration;

          const threshold = velocity > 0.5 ? 30 : 100;

          if (movedBy < -threshold && this.currentIndex < this.maxIndex) {
            this.currentIndex++;
          } else if (movedBy > threshold && this.currentIndex > 0) {
            this.currentIndex--;
          }

          this.updateSlider();
          this.startAutoplay();

          setTimeout(() => {
            this.hasDragged = false;
          }, 10);
        }

        getPositionX(event) {
          return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
        }
      }

      customElements.define('video-slider-{{ ai_gen_id }}', VideoSlider{{ ai_gen_id }});
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Product Shorts",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Metafield configuration"
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "youtube_shorts"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum items to display",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay videos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute videos",
      "default": true
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Video border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Slider layout"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides on desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_medium",
      "label": "Slides on medium devices",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides on mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Autoplay slides"
    },
    {
      "type": "checkbox",
      "id": "auto_change",
      "label": "Change slides automatically",
      "default": false
    },
    {
      "type": "range",
      "id": "auto_change_interval",
      "label": "Change slide every",
      "min": 1,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "Navigation controls"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "range",
      "id": "controls_spacing",
      "label": "Controls spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Arrow style"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Arrow size",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_color",
