{% doc %}
  @prompt
    I need a section that has an image background with an overlay, I need to have 4 icons  with title and text under each icon. The desktop view has to show the icons horizontally and on mobile one under each other., I need to upload my own icons, I need to have separate images for desktop and mobile
{% enddoc %}

{%- assign ai_gen_id = block.id | replace: '_', '' | downcase -%}

{%- liquid
  if block.settings.loading_eager
    assign loading_val = 'eager'
    assign fetchpriority_val = 'high'
  else
    assign loading_val = 'lazy'
    assign fetchpriority_val = 'auto'
  endif
-%}

{% style %}
  .ai-icon-features-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-icon-features-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-icon-features-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-icon-features-background-{{ ai_gen_id }} picture,
  .ai-icon-features-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-icon-features-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-features-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-icon-features-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-icon-features-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-icon-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-icon-feature-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-icon-feature-icon-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.icon_spacing }}px;
  }

  .ai-icon-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-icon-feature-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-features-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-icon-features-content-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-icon-features-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}

<div class="ai-icon-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-features-container-{{ ai_gen_id }}">

    <div class="ai-icon-features-background-{{ ai_gen_id }}">
      {%- if block.settings.background_image_desktop or block.settings.background_image_mobile -%}
        {%- assign mobile_bg = block.settings.background_image_mobile | default: block.settings.background_image_desktop -%}
        <picture>
          <source
            media="(max-width: 749px)"
            srcset="
              {{ mobile_bg | image_url: width: 375 }} 375w,
              {{ mobile_bg | image_url: width: 750 }} 750w,
              {{ mobile_bg | image_url: width: 1000 }} 1000w
            "
            sizes="100vw"
          >
          {%- if block.settings.background_image_desktop -%}
            {{-
              block.settings.background_image_desktop
              | image_url: width: 3840
              | image_tag:
                widths: '1100, 1500, 1780, 2000, 3000, 3840',
                sizes: '100vw',
                loading: loading_val,
                fetchpriority: fetchpriority_val,
                alt: block.settings.background_image_desktop.alt
            -}}
          {%- else -%}
            {{-
              block.settings.background_image_mobile
              | image_url: width: 1000
              | image_tag:
                widths: '375, 750, 1000',
                sizes: '100vw',
                loading: loading_val,
                fetchpriority: fetchpriority_val,
                alt: block.settings.background_image_mobile.alt
            -}}
          {%- endif -%}
        </picture>
      {%- else -%}
        <div class="ai-icon-features-background-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    <div class="ai-icon-features-overlay-{{ ai_gen_id }}"></div>

    <div class="ai-icon-features-content-{{ ai_gen_id }}">
      <div class="ai-icon-features-grid-{{ ai_gen_id }}">
        {%- for i in (1..6) -%}
          {%- liquid
            assign title_key = 'feature_' | append: i | append: '_title'
            assign text_key  = 'feature_' | append: i | append: '_text'
            assign icon_key  = 'feature_' | append: i | append: '_icon'

            assign title = block.settings[title_key]
            assign text  = block.settings[text_key]
            assign icon  = block.settings[icon_key]
          -%}

          <div class="ai-icon-feature-item-{{ ai_gen_id }}" data-animation="block" data-animation-group="{{ block.id }}">
            <div class="ai-icon-feature-icon-wrapper-{{ ai_gen_id }}">
              {%- render 'section-full-icon',
                custom_icon: icon,
                icon_background: block.settings.icon_background_style,
                icon_background_color: block.settings.icon_background_color,
                icon_color: block.settings.icon_color,
                icon_width: block.settings.icon_size
              -%}
            </div>

            {%- if title != blank -%}
              <h3 class="ai-icon-feature-title-{{ ai_gen_id }}">{{ title }}</h3>
            {%- endif -%}

            {%- if text != blank -%}
              <p class="ai-icon-feature-text-{{ ai_gen_id }}">{{ text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>

