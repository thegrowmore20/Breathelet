{% doc %}
  @prompt
    I need a section like the logo list but with the option to insert a title and a text under each logo
{% enddoc %}

{%- assign ai_gen_id = block.id | replace: '_', '' | downcase -%}

{%- liquid
  assign cols_mobile  = block.settings.columns_mobile  | plus: 0
  assign cols_desktop = block.settings.columns_desktop | plus: 0
  assign sizes_str = '(max-width: 749px) calc((100vw - 2rem) / ' | append: cols_mobile | append: '), calc((100vw - 4rem) / ' | append: cols_desktop | append: ')'
-%}

{% style %}
  .ai-logo-grid-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    display: block;
  }

  .ai-logo-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-logo-grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    transition: transform 0.3s ease;
    will-change: transform;
  }

  .ai-logo-grid-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-logo-grid-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    margin-bottom: {{ block.settings.spacing_below_logo }}px;
  }

  .ai-logo-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-logo-grid-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-grid-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing_below_title }}px;
  }

  .ai-logo-grid-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_font_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-logo-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-grid-container-{{ ai_gen_id }}">
    {%- for i in (1..6) -%}
      {%- liquid
        assign logo_key  = 'logo_'  | append: i
        assign title_key = 'title_' | append: i
        assign text_key  = 'text_'  | append: i

        assign logo  = block.settings[logo_key]
        assign title = block.settings[title_key]
        assign text  = block.settings[text_key]
      -%}

      <div class="ai-logo-grid-item-{{ ai_gen_id }}" data-animation="block" data-animation-group="{{ block.id }}">
        <div class="ai-logo-grid-image-wrapper-{{ ai_gen_id }}">
          {%- if logo -%}
            {{-
              logo
              | image_url: width: 400
              | image_tag:
                widths: '100, 150, 200, 300, 400',
                sizes: sizes_str,
                loading: 'lazy',
                alt: logo.alt,
                class: 'w-full h-auto block'
            -}}
          {%- else -%}
            <div class="ai-logo-grid-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

        {%- if title != blank -%}
          <h3 class="ai-logo-grid-title-{{ ai_gen_id }}">{{ title }}</h3>
        {%- endif -%}

        {%- if text != blank -%}
          <div class="ai-logo-grid-text-{{ ai_gen_id }}">{{ text }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

